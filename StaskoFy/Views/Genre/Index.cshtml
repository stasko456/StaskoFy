@model GenresPaginationViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xxl-10">

            <div class="card shadow-lg border-0 rounded-4 card-index">
                <div class="card-body p-5">

                    <div class="d-flex justify-content-between align-items-center w-100 py-4 px-3">

                        <div class="text-start">
                            <h1 class="fw-bold display-5 mb-0 d-flex align-items-center">
                                <svg viewBox="0 0 640 640" height="50" width="50" class="me-3">
                                    <path fill="white" d="M0 64C0 46.3 14.3 32 32 32l448 0c17.7 0 32 14.3 32 32l0 32c0 17.7-14.3 32-32 32L32 128C14.3 128 0 113.7 0 96L0 64zM32 176l448 0 0 240c0 35.3-28.7 64-64 64L96 480c-35.3 0-64-28.7-64-64l0-240zm152 64c-13.3 0-24 10.7-24 24s10.7 24 24 24l144 0c13.3 0 24-10.7 24-24s-10.7-24-24-24l-144 0z" />
                                </svg>
                                <span class="specific_heading">Genres</span>
                            </h1>
                            <p class="text-muted fs-5 mb-0 fw-semibold mt-1">
                                @Model.GenresCount Genres Available
                            </p>
                        </div>

                        <div id="search-bar-target" class="compact-search-group" style="max-width: 350px; width: 100%;">
                            <form  method="get" class="mb-0" asp-controller="Genre" asp-action="Index">
                                <div class="d-flex gap-2">
                                    <input class="form-control custom-search-input"
                                           type="search"
                                           placeholder="Search..."
                                           name="name"
                                           value="@Context.Request.Query["name"]" />
                                    <button type="submit" class="btn btn-search custom-search-btn shadow-sm">
                                        <svg viewBox="0 0 640 640" style="width:16px; height:16px; margin-right: 5px;">
                                            <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                        </svg>
                                        Search
                                    </button>
                                </div>
                            </form>
                        </div>

                    </div>

                    <hr class="mb-5" />

                    <div class="table-responsive">
                        <table class="table align-middle table-hover mb-0 fs-6">

                            <thead class="bg-light text-secondary">
                                <tr class="text-uppercase">
                                    <th class="ps-3">#</th>
                                    <th>Name</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int index = 1;
                                }
                                @if (!Model.Genres.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center">
                                            <div class="text-center py-5">
                                                <h4 class="text-white fw-light">@ViewData["NoResult"]</h4>
                                                <p class="text-secondary">Try searching for a different genre.</p>

                                                <div class="mt-4">
                                                    <a href="@Url.Action("Index", "Genre")" class="btn btn-outline-warning px-4 me-2">Clear Search</a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var genre in Model.Genres)
                                    {
                                        <tr class="border-top" id="genre-@genre.Id">

                                            <td class="ps-3 text-muted fw-semibold py-2">
                                                @index
                                            </td>

                                            <td class="fw-bold text-dark py-2 fs-5">
                                                @genre.Name
                                            </td>

                                            <td class="py-2">
                                                <div class="d-flex justify-content-center gap-3">

                                                    <a class="btn edit-button btn-md" asp-route-id="@genre.Id" asp-action="Edit">
                                                        <svg viewBox="0 0 512 512" width="20" height="20" class="me-2">
                                                            <path fill="currentColor" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z" />
                                                        </svg>
                                                        Edit
                                                    </a>

                                                    <form id="delete-form-@genre.Id" asp-action="Delete" method="post" asp-route-id="@genre.Id">
                                                        <button class="btn btn-outline-danger btn-md"
                                                            onclick="confirmDelete(event, 'delete-form-@genre.Id')">
                                                            <svg viewBox="0 0 448 512" width="20" height="20" class="me-2">
                                                                <path fill="currentColor" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                                            </svg>
                                                            Delete
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>

                                        </tr>

                                        index++;
                                    }
                                }
                            </tbody>

                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    <nav>
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-pageSize="3">Previous</a>
                </li>
            }

            @if (Model.CurrentPage > 2)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="1" asp-route-pageSize="3">1</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            @for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
            {
                if (i > 0 && i <= Model.TotalPages)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-pageSize="3">@i</a>
                    </li>
                }
            }

            @if (Model.CurrentPage < Model.TotalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="3">@Model.TotalPages</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-pageSize="3">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>