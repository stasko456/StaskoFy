@model GenreEditViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-xl-6">
            <div class="card shadow-lg border-0 rounded-4 card-edit">
                <div class="card-body p-4 p-md-5">
                    <h2 class="text-center mb-4 fw-bold">
                        Edit <span class="text-warning">Genre</span>
                        <svg viewBox="0 0 640 640" height="50" width="50" class="ms-1">
                            <path fill="rgb(255, 255, 255)" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z" />
                        </svg>
                    </h2>
                    <form method="post" asp-action="Edit">
                        <div class="mb-5">
                            <label asp-for="Name" class="form-label fw-semibold">Genre Name</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Enter genre name" aria-required="true" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                                <button type="submit" class="btn btn-warning btn-lg rounded-4 px-5 shadow fw-semibold">
                                    Save Changes
                                </button>
                                <a asp-controller="Genre" asp-action="Index"
                                   class="btn btn-outline-warning btn-lg rounded-4 px-4">
                                    Cancel
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}