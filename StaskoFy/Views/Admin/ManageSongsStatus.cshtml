@model List<SongApprovalViewModel>

<h2>Pending Song Approvals</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Artist</th>
            <th>Genre</th>
            <th>Created On</th>
            <th>Actions</th>
        </tr>
    </thead>

    ```
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var song in Model)
            {
                <tr>
                    <td>@song.Title</td>
                    <td>
                        @foreach (var artist in song.Artists)
                        {
                            <span class="badge bg-light text-dark border rounded-pill me-1 px-3">
                                @artist
                            </span>
                        }
                    </td>
                    <td>@song.Genre</td>
                    <td>@song.Status.ToString()</td>
                    <td>
                        <form method="post" asp-controller="Song" asp-action="AcceptSongUpload" asp-route-id="@song.Id">
                            <button type="submit" class="btn btn-success btn-sm">Accept</button>
                        </form>
                        <form method="post" asp-controller="Song" asp-action="RejectSongUpload" asp-route-id="@song.Id">
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">
                    No songs waiting for approval.
                </td>
            </tr>
        }
    </tbody>
</table>