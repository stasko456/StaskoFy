@model List<AlbumApprovalViewModel>

<h2>Pending Album Approvals</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Length</th>
            <th>Release Date</th>
            <th>Songs Count</th>
            <th>Artist</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    ```
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var album in Model)
            {
                <tr>
                    <td>@album.Title</td>
                    <td>@album.Hours.ToString("D2"):@album.Minutes.ToString("D2"):@album.Seconds.ToString("D2")</td>
                    <td>@album.ReleaseDate.ToString("dd MMM yyyy")</td>
                    <td>@album.SongsCount</td>
                    <td>
                        @foreach (var artist in album.Artists)
                        {
                            <span class="badge bg-light text-dark border rounded-pill me-1 px-3">
                                @artist
                            </span>
                        }
                    </td>
                    <td>@album.Status.ToString()</td>
                    <td>
                        <form method="post" asp-controller="Album" asp-action="AcceptAlbumUpload" asp-route-id="@album.Id">
                            <button type="submit" class="btn btn-success btn-sm">Accept</button>
                        </form>
                        <form method="post" asp-controller="Album" asp-action="RejectAlbumUpload" asp-route-id="@album.Id">
                            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">
                    No songs waiting for approval.
                </td>
            </tr>
        }
    </tbody>
</table>