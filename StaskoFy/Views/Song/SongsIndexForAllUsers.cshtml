@model SongsPageViewModel

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">
        Discover <span class="text-warning">Songs</span>
    </h1>
    @if (User.IsInRole("Admin"))
    {
        <p class="text-muted">Browse all songs on the platform and <span class="text-danger">remove</span> any that <span class="text-danger">violate the rules</span>.</p>
    }
    else
    {
        <p class="text-muted">Explore all songs on the platform</p>
    }
</div>

<div class="row justify-content-center w-100 mx-0">
    <div class="col-12 col-md-8 col-lg-6 mb-4 mx-auto">
        <form asp-controller="Song" asp-action="SongsIndexForAllUsers" method="get">
            <div class="d-flex align-items-center gap-4 mb-4">
                <input class="form-control form-control-lg"
                       type="search"
                       placeholder="Search songs..."
                       name="searchItem"
                       value="@Context.Request.Query["searchItem"]" />
                <button type="submit" class="btn btn-warning btn-lg fw-semibold d-inline-flex align-items-center">
                    <svg viewBox="0 0 640 640" width="30" height="30" class="me-2">
                        <path fill="rgb(255, 255, 255)" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                    </svg>
                    Search
                </button>
            </div>

            <div class="d-flex align-items-center justify-content-center gap-4">
                <div>
                    <input class="form-check-input" type="checkbox" name="filters" value="Title"
                           @(Context.Request.Query["filters"].Contains("Title") ? "checked" : "") />
                    <label class="form-check-label fw-semibold">By Title</label>
                </div>
                <div>
                    <input class="form-check-input" type="checkbox" name="filters" value="Album"
                           @(Context.Request.Query["filters"].Contains("Album") ? "checked" : "") />
                    <label class="form-check-label fw-semibold">By Album</label>
                </div>
                <div>
                    <input class="form-check-input" type="checkbox" name="filters" value="Genre"
                           @(Context.Request.Query["filters"].Contains("Genre") ? "checked" : "") />
                    <label class="form-check-label fw-semibold">By Genre</label>
                </div>
                <div>
                    <input class="form-check-input" type="checkbox" name="filters" value="Artist"
                           @(Context.Request.Query["filters"].Contains("Artist") ? "checked" : "") />
                    <label class="form-check-label fw-semibold">By Artist</label>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Songs.Any())
{
    <div class="alert alert-danger rounded-4 text-center fw-semibold shadow-sm fs-3">
        <i class="bi bi-search me-2"></i>
        @ViewData["NoResult"]
    </div>
}
else
{
    <div class="container my-5">
        <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 justify-content-center mx-auto"
             style="max-width: 1200px;">

            @foreach (var song in Model.Songs)
            {
                <div class="col mb-4">
                    <div class="card h-100 shadow-sm border-0 overflow-hidden" style="transition: transform 0.2s; border-radius: 12px;">

                        <div style="position: relative; width: 100%; padding-bottom: 100%; background-color: #f8f9fa; border-radius: 12px 12px 0 0; overflow: hidden;">
                            <a asp-action="Details">
                                <img src="@song.ImageURL"
                                     alt="@song.Title"
                                     style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain;">
                            </a>
                        </div>

                        <div class="card-body p-3 d-flex flex-column">
                            <h6 class="card-title mb-1 text-truncate" title="@song.Title" style="font-weight: 700; font-size: 0.9rem;">
                                @song.Title
                            </h6>

                            <div class="mt-auto">
                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-controller="Song" asp-action="Delete" method="post" asp-route-id="@song.Id">
                                        <button class="btn btn-outline-danger btn-sm w-100 py-1" style="border-radius: 6px;">
                                            Delete
                                        </button>
                                    </form>
                                }
                                else if (User.IsInRole("Artist") || User.IsInRole("User"))
                                {
                                    <div class="dropup mt-auto">
                                        <button class="btn btn-sm btn-secondary dropdown-toggle"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false">
                                            <svg viewBox="0 0 640 640" width="18" height="18" class="me-2">
                                                <path fill="rgb(255, 255, 255)" d="M96 320C96 289.1 121.1 264 152 264C182.9 264 208 289.1 208 320C208 350.9 182.9 376 152 376C121.1 376 96 350.9 96 320zM264 320C264 289.1 289.1 264 320 264C350.9 264 376 289.1 376 320C376 350.9 350.9 376 320 376C289.1 376 264 350.9 264 320zM488 264C518.9 264 544 289.1 544 320C544 350.9 518.9 376 488 376C457.1 376 432 350.9 432 320C432 289.1 457.1 264 488 264z" />
                                            </svg>
                                        </button>

                                        <ul class="dropdown-menu dropdown-menu-dark shadow">
                                            <li class="dropdown-submenu">
                                                <a class="dropdown-item dropdown-toggle" style="cursor: pointer;">
                                                    <svg viewBox="0 0 448 512" width="18" height="18" class="me-2">
                                                        <path fill="rgb(255, 255, 255)" d="M64 80c-8.8 0-16 7.2-16 16l0 320c0 8.8 7.2 16 16 16l320 0c8.8 0 16-7.2 16-16l0-320c0-8.8-7.2-16-16-16L64 80zM0 96C0 60.7 28.7 32 64 32l320 0c35.3 0 64 28.7 64 64l0 320c0 35.3-28.7 64-64 64L64 480c-35.3 0-64-28.7-64-64L0 96zM200 344l0-64-64 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l64 0 0-64c0-13.3 10.7-24 24-24s24 10.7 24 24l0 64 64 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-64 0 0 64c0 13.3-10.7 24-24 24s-24-10.7-24-24z" />
                                                    </svg>
                                                    <span>Add to Playlist</span>
                                                </a>
                                                <ul class="dropdown-menu dropdown-menu-dark shadow">
                                                    @if (Model.Playlists != null && Model.Playlists.Any())
                                                    {
                                                        foreach (var playlist in Model.Playlists)
                                                        {
                                                            <li>
                                                                <form method="post" asp-controller="Playlist" asp-action="AddSongToPlaylist">
                                                                    <input type="hidden" name="playlistId" value="@playlist.Id" />
                                                                    <input type="hidden" name="songId" value="@song.Id" />
                                                                    <button type="submit" class="dropdown-item">@playlist.Title</button>
                                                                </form>
                                                            </li>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <li><span class="dropdown-item-text text-muted">No playlists found</span></li>
                                                    }
                                                </ul>
                                            </li>

                                            <li><hr class="dropdown-divider" /></li>

                                            <li>
                                                <form method="post" asp-controller="LikedSongs" asp-action="AddLikedSong" asp-route-songId="@song.Id">
                                                    <button type="submit" class="dropdown-item">Add to Liked Songs</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}