@model SongsPaginationViewModel

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">
        Discover <span class="specific_heading">Songs</span>
    </h1>
    @if (User.IsInRole("Admin"))
    {
        <p class="text-muted">Browse all songs on the platform and <span class="text-danger">remove</span> any that <span class="text-danger">violate the rules</span>.</p>
    }
    else
    {
        <p class="text-muted">Explore all songs on the platform</p>
    }
</div>

<div class="row justify-content-center w-100 mx-0">
    <div class="col-12 col-md-8 col-lg-6 mb-4 mx-auto">
        <form asp-controller="Song" asp-action="SongsIndexForAllUsers" method="get">
            <div class="d-flex align-items-center gap-4 mb-4">
                <input class="form-control form-control-lg"
                       type="search"
                       placeholder="Search songs..."
                       name="searchItem"
                       value="@Context.Request.Query["searchItem"]" />
                <button type="submit" class="btn btn-search custom-gold-button btn-lg d-inline-flex align-items-center px-4">
                    <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                    </svg>
                    Search
                </button>
            </div>

            <div class="d-flex align-items-center justify-content-center gap-4">
                <div>
                    <input type="radio" class="btn-check" id="filter-title" autocomplete="off" name="filters" value="Title"
                    @(Context.Request.Query["filters"] == "Title" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-title">By Title</label>
                </div>

                <div>
                    <input type="radio" class="btn-check" id="filter-album" autocomplete="off" name="filters" value="Album"
                    @(Context.Request.Query["filters"] == "Album" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-album">By Album</label>
                </div>

                <div>
                    <input type="radio" class="btn-check" id="filter-genre" autocomplete="off" name="filters" value="Genre"
                    @(Context.Request.Query["filters"] == "Genre" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-genre">By Genre</label>
                </div>

                <div>
                    <input type="radio" class="btn-check" id="filter-artist" autocomplete="off" name="filters" value="Artist"
                    @(Context.Request.Query["filters"] == "Artist" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-artist">By Artist</label>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Songs.Any())
{
    <div class="alert alert-danger rounded-4 text-center fw-semibold shadow-sm fs-3">
        <i class="bi bi-search me-2"></i>
        @ViewData["NoResult"]
    </div>
}
else
{
    <div class="container my-5">
        <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 justify-content-center mx-auto"
             style="max-width: 1200px;">

            @foreach (var song in Model.Songs)
            {
                <div class="col" id="song-@song.Id">
                    <div class="card h-100 border-0 song-card-container"
                         style="border-radius: 12px; background-color: #1a1a1a; transition: transform 0.3s ease, box-shadow 0.3s ease; overflow: visible;">

                        <div style="position: relative; width: 100%; padding-bottom: 100%; background-color: #2a2a2a; border-radius: 12px 12px 0 0; overflow: hidden;">
                            <a asp-controller="Song" asp-action="Details" asp-route-id="@song.Id">
                                <img src="@song.ImageURL"
                                     alt="@song.Title"
                                     style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                            </a>
                        </div>

                        <div class="card-body p-3 d-flex flex-column">
                            <div class="d-flex align-items-center justify-content-between w-100 mb-3">
                                <div class="flex-grow-1 overflow-hidden">
                                    <h6 class="card-title mb-0 text-truncate text-white"
                                        title="@song.Title"
                                        style="font-weight: 700; font-size: 0.95rem;">
                                        @song.Title
                                    </h6>
                                </div>

                                <button class="btn p-0 play-btn-custom"
                                        type="button"
                                        data-song-id="@song.Id"
                                        onclick="loadSong('@song.Id')">
                                    <svg viewBox="0 0 640 640" height="40" width="40" style="background-color:transparent">
                                        <path fill="#ffc107" d="M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z" />
                                    </svg>
                                </button>
                            </div>

                            <div class="mt-auto">
                                @if (User.IsInRole("Admin"))
                                {
                                    <form id="delete-form-@song.Id" asp-controller="Song" asp-action="Delete" method="post" asp-route-id="@song.Id">
                                        <input type="hidden" name="sourceController" value="@ViewContext.RouteData.Values["controller"]" />
                                        <input type="hidden" name="sourceAction" value="@ViewContext.RouteData.Values["action"]" />
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm w-100 py-2 d-flex align-items-center justify-content-center"
                                                style="border-radius: 8px; font-weight: 600;"
                                                onclick="confirmDelete(event, 'delete-form-@song.Id')">
                                            <svg viewBox="0 0 448 512" width="14" height="14" class="me-2">
                                                <path fill="currentColor" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                            </svg>Delete
                                        </button>
                                    </form>
                                }
                                else if (User.IsInRole("Artist") || User.IsInRole("User"))
                                {
                                    <div class="dropup">
                                        <button class="btn btn-sm w-100 d-flex align-items-center justify-content-center py-2"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false"
                                                style="background-color: rgba(255,255,255,0.07); color: #ffffff; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; font-weight: 600;">
                                            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" class="me-2">
                                                <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
                                            </svg>
                                            Options
                                        </button>

                                        <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary" style="border-radius: 10px; padding: 8px 0;">
                                            <li class="dropdown-submenu position-relative">
                                                <a class="dropdown-item d-flex align-items-center py-2" style="cursor: pointer;">
                                                    <svg viewBox="0 0 640 640" width="18" height="18" class="me-2 text-white">
                                                        <path fill="currentColor" d="M64 80c-8.8 0-16 7.2-16 16l0 320c0 8.8 7.2 16 16 16l320 0c8.8 0 16-7.2 16-16l0-320c0-8.8-7.2-16-16-16L64 80zM0 96C0 60.7 28.7 32 64 32l320 0c35.3 0 64 28.7 64 64l0 320c0 35.3-28.7 64-64 64L64 480c-35.3 0-64-28.7-64-64L0 96zM200 344l0-64-64 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l64 0 0-64c0-13.3 10.7-24 24-24s24 10.7 24 24l0 64 64 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-64 0 0 64c0 13.3-10.7 24-24 24s-24-10.7-24-24z" />
                                                    </svg>
                                                    <span>Add to Playlist</span>
                                                </a>
                                                <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary" style="border-radius: 10px;">
                                                    @if (Model.CurrentLoggedUserPlaylists != null && Model.CurrentLoggedUserPlaylists.Any())
                                                    {
                                                        foreach (var playlist in Model.CurrentLoggedUserPlaylists)
                                                        {
                                                            <li>
                                                                <form method="post" asp-controller="Playlist" asp-action="AddSongToPlaylist">
                                                                    <input type="hidden" name="playlistId" value="@playlist.Id" />
                                                                    <input type="hidden" name="songId" value="@song.Id" />
                                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#song-@song.Id" />
                                                                    <button type="submit" class="dropdown-item py-2">@playlist.Title</button>
                                                                </form>
                                                            </li>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <li><span class="dropdown-item-text text-muted small">No playlists found</span></li>
                                                    }
                                                </ul>
                                            </li>

                                            <li><hr class="dropdown-divider border-secondary" /></li>

                                            <li>
                                                <form method="post" asp-controller="LikedSongs" asp-action="AddLikedSong" asp-route-songId="@song.Id">
                                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#song-@song.Id" />
                                                    <button type="submit" class="dropdown-item py-2">
                                                        Add to Liked Songs
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<div class="d-flex justify-content-center mt-4">
    <nav>
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="SongsIndexForAllUsers" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-pageSize="3">Previous</a>
                </li>
            }

            @if (Model.CurrentPage > 2)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="SongsIndexForAllUsers" asp-route-pageNumber="1" asp-route-pageSize="3">1</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            @for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
            {
                if (i > 0 && i <= Model.TotalPages)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="SongsIndexForAllUsers" asp-route-pageNumber="@i" asp-route-pageSize="3">@i</a>
                    </li>
                }
            }

            @if (Model.CurrentPage < Model.TotalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="SongsIndexForAllUsers" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="3">@Model.TotalPages</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="SongsIndexForAllUsers" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-pageSize="3">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>