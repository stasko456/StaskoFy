@using Microsoft.AspNetCore.Identity
@using StaskoFy.Models.Entities;
@inject UserManager<User> userManager
@inject SignInManager<User> signInManager

@{
    var currentLoggedUser = await userManager.GetUserAsync(User);
    var pfp = currentLoggedUser?.ImageURL.ToString();
}

<div class="navbar-collapse collapse justify-content-end">
<ul class="navbar-nav">
    @if (signInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link btn btn-link text-white" title="Manage" asp-controller="User" asp-action="Manage">
                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                        <path fill="rgb(255, 255, 255)" d="M406.5 399.6C387.4 352.9 341.5 320 288 320l-64 0c-53.5 0-99.4 32.9-118.5 79.6-35.6-37.3-57.5-87.9-57.5-143.6 0-114.9 93.1-208 208-208s208 93.1 208 208c0 55.7-21.9 106.2-57.5 143.6zm-40.1 32.7C334.4 452.4 296.6 464 256 464s-78.4-11.6-110.5-31.7c7.3-36.7 39.7-64.3 78.5-64.3l64 0c38.8 0 71.2 27.6 78.5 64.3zM256 512a256 256 0 1 0 0-512 256 256 0 1 0 0 512zm0-272a40 40 0 1 1 0-80 40 40 0 1 1 0 80zm-88-40a88 88 0 1 0 176 0 88 88 0 1 0 -176 0z" />
                    </svg>Hello @User?.Identity?.Name!
                </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-controller="User" asp-action="Logout">
                    <button type="submit" class="nav-link btn btn-link text-white">
                        <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                            <path fill="currentColor" d="M352 96l64 0c17.7 0 32 14.3 32 32l0 256c0 17.7-14.3 32-32 32l-64 0c-17.7 0-32 14.3-32 32s14.3 32 32 32l64 0c53 0 96-43 96-96l0-256c0-53-43-96-96-96l-64 0c-17.7 0-32 14.3-32 32s14.3 32 32 32zm-9.4 182.6c12.5-12.5 12.5-32.8 0-45.3l-128-128c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L242.7 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l210.7 0-73.4 73.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l128-128z" />
                        </svg>Logout
                    </button>
            </form>
        </li>
        <li class="nav-item">
                <a class="nav-link text-dark" title="Profile" asp-controller="User" asp-action="Details">
                <img src="@pfp" alt="Profile" class="rounded-circle" style="width:30px; height:30px; object-fit:cover;">
            </a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link btn btn-link text-white" asp-controller="User" asp-action="Register">
                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                        <path fill="rgb(255, 255, 255)" d="M285.7 304c98.5 0 178.3 79.8 178.3 178.3 0 16.4-13.3 29.7-29.7 29.7L77.7 512C61.3 512 48 498.7 48 482.3 48 383.8 127.8 304 226.3 304l59.4 0zM528 80c13.3 0 24 10.7 24 24l0 48 48 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-48 0 0 48c0 13.3-10.7 24-24 24s-24-10.7-24-24l0-48-48 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l48 0 0-48c0-13.3 10.7-24 24-24zM256 248a120 120 0 1 1 0-240 120 120 0 1 1 0 240z" />
                    </svg>Register
                </a>
        </li>
        <li class="nav-item">
            <a class="nav-link btn btn-link text-white" asp-controller="User" asp-action="Login">
                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                        <path fill="currentColor" d="M352 96l64 0c17.7 0 32 14.3 32 32l0 256c0 17.7-14.3 32-32 32l-64 0c-17.7 0-32 14.3-32 32s14.3 32 32 32l64 0c53 0 96-43 96-96l0-256c0-53-43-96-96-96l-64 0c-17.7 0-32 14.3-32 32s14.3 32 32 32zm-9.4 182.6c12.5-12.5 12.5-32.8 0-45.3l-128-128c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L242.7 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l210.7 0-73.4 73.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l128-128z" />
                    </svg>Login
                </a>
        </li>
    }
</ul>
</div>