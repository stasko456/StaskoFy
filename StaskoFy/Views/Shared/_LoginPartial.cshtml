@using Microsoft.AspNetCore.Identity
@using StaskoFy.Models.Entities;
@inject UserManager<User> userManager
@inject SignInManager<User> signInManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<ul class="navbar-nav">
    @if (signInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" title="Manage" asp-controller="User" asp-action="Manage">Hello @User?.Identity?.Name!</a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-controller="User" asp-action="Logout">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark @(currentController == "User" && currentAction == "Register" ? "active" : "")" asp-controller="User" asp-action="Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark @(currentController == "User" && currentAction == "Login" ? "active" : "")" asp-controller="User" asp-action="Login">Login</a>
        </li>
    }
</ul>