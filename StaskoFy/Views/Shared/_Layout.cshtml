<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StaskoFy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StaskoFy.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2/theme-dark@4/dark.css" />
</head>
<body>
    <header>
        @{
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        }
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link btn btn-link text-white @(currentAction == "Index" && currentController == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                                <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                    <path fill="currentColor" d="M240 6.1c9.1-8.2 22.9-8.2 32 0l232 208c9.9 8.8 10.7 24 1.8 33.9s-24 10.7-33.9 1.8l-8-7.2 0 205.3c0 35.3-28.7 64-64 64l-288 0c-35.3 0-64-28.7-64-64l0-205.3-8 7.2c-9.9 8.8-25 8-33.9-1.8s-8-25 1.8-33.9L240 6.1zm16 50.1L96 199.7 96 448c0 8.8 7.2 16 16 16l48 0 0-104c0-39.8 32.2-72 72-72l48 0c39.8 0 72 32.2 72 72l0 104 48 0c8.8 0 16-7.2 16-16l0-248.3-160-143.4zM208 464l96 0 0-104c0-13.3-10.7-24-24-24l-48 0c-13.3 0-24 10.7-24 24l0 104z" />
                                </svg>Home</a>
                        </li>
                        @if ((User?.Identity?.IsAuthenticated ?? false) && (User.IsInRole("Admin")))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" data-bs-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">Manage Genres</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item text-white" asp-controller="Genre" asp-action="Index">View genres</a>
                                    <a class="dropdown-item text-white" asp-controller="Genre" asp-action="Create">Create genre</a>
                                </div>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" data-bs-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">Manage Uploads</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item text-white" asp-controller="Admin" asp-action="ManageSongsStatus">Manage songs</a>
                                    <a class="dropdown-item text-white" asp-controller="Admin" asp-action="ManageAlbumsStatus">Manage albums</a>
                                    <a class="dropdown-item text-white" asp-controller="Admin" asp-action="ManageGenresStatus">Manage genres</a>
                                    <a class="dropdown-item text-white" asp-controller="Admin" asp-action="ManageArtistsStatus">Manage artists</a>
                                </div>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "SongsIndexForAllUsers" && currentController == "Song" ? "active" : "")" asp-controller="Song" asp-action="SongsIndexForAllUsers">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Songs
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "AlbumsIndexForAllUsers" && currentController == "Album" ? "active" : "")" asp-controller="Album" asp-action="AlbumsIndexForAllUsers">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Albums
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "Index" && currentController == "User" ? "active" : "")" asp-controller="User" asp-action="Index">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Users
                                </a>
                            </li>
                        }
                        else if ((User?.Identity?.IsAuthenticated ?? false) && (User.IsInRole("Artist")))
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "SongsIndexForAllUsers" && currentController == "Song" ? "active" : "")" asp-controller="Song" asp-action="SongsIndexForAllUsers">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Songs
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "AlbumsIndexForAllUsers" && currentController == "Album" ? "active" : "")" asp-controller="Album" asp-action="AlbumsIndexForAllUsers">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Albums
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "Index" && currentController == "User" ? "active" : "")" asp-controller="User" asp-action="Index">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Users
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "MyLibraryIndex" && currentController == "Library" ? "active" : "")" asp-controller="Library" asp-action="MyLibraryIndex">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M96 512l320 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l0-66.7c18.6-6.6 32-24.4 32-45.3l0-288c0-26.5-21.5-48-48-48l-48 0 0 169.4c0 12.5-10.1 22.6-22.6 22.6-6 0-11.8-2.4-16-6.6L272 144 230.6 185.4c-4.2 4.2-10 6.6-16 6.6-12.5 0-22.6-10.1-22.6-22.6L192 0 96 0C43 0 0 43 0 96L0 416c0 53 43 96 96 96zM64 416c0-17.7 14.3-32 32-32l256 0 0 64-256 0c-17.7 0-32-14.3-32-32z" />
                                    </svg>My Library</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "MyProjectsForCurrentLoggedArtistIndex" && currentController == "Library" ? "active" : "")" asp-controller="Library" asp-action="MyProjectsForCurrentLoggedArtistIndex">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M256 109.3L256 320c0 17.7-14.3 32-32 32s-32-14.3-32-32l0-210.7-41.4 41.4c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3l96-96c12.5-12.5 32.8-12.5 45.3 0l96 96c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L256 109.3zM224 400c44.2 0 80-35.8 80-80l80 0c35.3 0 64 28.7 64 64l0 32c0 35.3-28.7 64-64 64L64 480c-35.3 0-64-28.7-64-64l0-32c0-35.3 28.7-64 64-64l80 0c0 44.2 35.8 80 80 80zm144 24a24 24 0 1 0 0-48 24 24 0 1 0 0 48z" />
                                    </svg>My Projects
                                </a>
                            </li>
                        }
                        else if ((User?.Identity?.IsAuthenticated ?? false) && (User.IsInRole("User")))
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "SongsIndexForAllUsers" && currentController == "Song" ? "active" : "")" asp-controller="Song" asp-action="SongsIndexForAllUsers">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Songs
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "AlbumsIndexForAllUsers" && currentController == "Album" ? "active" : "")" asp-controller="Album" asp-action="AlbumsIndexForAllUsers">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Albums
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "Index" && currentController == "User" ? "active" : "")" asp-controller="User" asp-action="Index">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                    </svg>Browse Users
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-link text-white @(currentAction == "MyLibraryIndex" && currentController == "Library" ? "active" : "")" asp-controller="Library" asp-action="MyLibraryIndex">
                                    <svg viewBox="0 0 640 640" width="20" height="20" class="me-1">
                                        <path fill="currentColor" d="M96 512l320 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l0-66.7c18.6-6.6 32-24.4 32-45.3l0-288c0-26.5-21.5-48-48-48l-48 0 0 169.4c0 12.5-10.1 22.6-22.6 22.6-6 0-11.8-2.4-16-6.6L272 144 230.6 185.4c-4.2 4.2-10 6.6-16 6.6-12.5 0-22.6-10.1-22.6-22.6L192 0 96 0C43 0 0 43 0 96L0 416c0 53 43 96 96 96zM64 416c0-17.7 14.3-32 32-32l256 0 0 64-256 0c-17.7 0-32-14.3-32-32z" />
                                    </svg>My Library
                                </a>
                            </li>
                        }
                    </ul>
                </div>
                @RenderSection("_SearchBarPartial", required: false)
                <partial name="_LoginPartial" />
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted position-fixed">
        <div class="container d-flex flex-column justify-content-center align-items-center">
            <div>
                <h3 class="specific_heading fw-bold mt-2">Song's title</h3>
            </div>
            <div>
                <button class="btn">
                    <svg viewBox="0 0 640 640" height="50" width="50" style="background-color:transparent">
                        <path fill="#ffc107" d="M236.3 107.1C247.9 96 265 92.9 279.7 99.2C294.4 105.5 304 120 304 136L304 272.3L476.3 107.2C487.9 96 505 92.9 519.7 99.2C534.4 105.5 544 120 544 136L544 504C544 520 534.4 534.5 519.7 540.8C505 547.1 487.9 544 476.3 532.9L304 367.7L304 504C304 520 294.4 534.5 279.7 540.8C265 547.1 247.9 544 236.3 532.9L44.3 348.9C36.5 341.3 32 330.9 32 320C32 309.1 36.5 298.7 44.3 291.1L236.3 107.1z" />
                    </svg>
                </button>
                <button class="btn">
                    <svg viewBox="0 0 640 640" height="50" width="50" style="background-color:transparent">
                        <path fill="#ffc107" d="M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z" />
                    </svg>
                </button>
                <button class="btn">
                    <svg viewBox="0 0 640 640" height="50" width="50" style="background-color:transparent">
                        <path fill="#ffc107" d="M403.7 107.1C392.1 96 375 92.9 360.3 99.2C345.6 105.5 336 120 336 136L336 272.3L163.7 107.2C152.1 96 135 92.9 120.3 99.2C105.6 105.5 96 120 96 136L96 504C96 520 105.6 534.5 120.3 540.8C135 547.1 152.1 544 163.7 532.9L336 367.7L336 504C336 520 345.6 534.5 360.3 540.8C375 547.1 392.1 544 403.7 532.9L595.7 348.9C603.6 341.4 608 330.9 608 320C608 309.1 603.5 298.7 595.7 291.1L403.7 107.1z" />
                    </svg>
                </button>
            </div>
            <div>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" aria-valuenow="40"
                         aria-valuemin="0" aria-valuemax="100" style="width:40%">
                        40% Complete (success)
                    </div>
                </div>
            </div>
            @* &copy; 2026 - StaskoFy - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a> *@
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>