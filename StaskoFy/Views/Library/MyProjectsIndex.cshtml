@model MyProjectsViewModel

<div class="text-center mb-5 fade-in-up">
    <h1 class="display-4 fw-bold mb-3">
        Your <span class="specific_heading"> Music Projects</span>
    </h1>

    <p class="lead text-dark mb-1">
        Explore your projects and make new ones.
    </p>
</div>

<div class="container mt-4 fade-in-up" style="animation-delay: 0.1s;">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <ul class="nav nav-pills" id="pills-tab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="pills-singles-tab" data-bs-toggle="pill" data-bs-target="#pills-singles" type="button" role="tab">Singles & Features</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="pills-albums-tab" data-bs-toggle="pill" data-bs-target="#pills-albums" type="button" role="tab">Albums</button>
            </li>
        </ul>

        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Song" asp-action="Create" class="btn btn-outline-warning btn-md d-inline-flex align-items-center" hx-boost="false">
                <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                    <path fill="currentColor" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM296 408L296 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296L296 296L296 232C296 218.7 306.7 208 320 208C333.3 208 344 218.7 344 232L344 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L344 344L344 408C344 421.3 333.3 432 320 432C306.7 432 296 421.3 296 408z" />
                </svg>Upload music
            </a>

            <a asp-controller="Album" asp-action="Create" class="btn btn-outline-warning btn-md d-inline-flex align-items-center" hx-boost="false">
                <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                    <path fill="currentColor" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM296 408L296 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296L296 296L296 232C296 218.7 306.7 208 320 208C333.3 208 344 218.7 344 232L344 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L344 344L344 408C344 421.3 333.3 432 320 432C306.7 432 296 421.3 296 408z" />
                </svg>Upload album
            </a>
        </div>
    </div>

    <hr />

    <div class="tab-content" id="pills-tabContent">
        <div class="tab-pane fade show active" id="pills-singles" role="tabpanel" aria-labelledby="pills-singles-tab">
            <div class="text-light text-center">
                <h3 class="fw-bold mb-3">
                    Your <span class="specific_heading">Singles & Features</span>
                </h3>
            </div>

            @if (!Model.Singles.Any())
            {
                <div class="border border-secondary border-opacity-50 rounded-4 text-center py-5 px-3 mb-5 shadow-sm">
                    <div class="mb-3">
                        <svg viewBox="0 0 384 512" height="70" width="70">
                            <path fill="#ffc107" d="M381.9 388.2c-6.4 27.4-27.2 42.8-55.1 48-24.5 4.5-44.9 5.6-64.5-10.2-23.9-20.1-24.2-53.4-2.7-74.4 17-16.2 40.9-19.5 76.8-25.8 6-1.1 11.2-2.5 15.6-7.4 6.4-7.2 4.4-4.1 4.4-163.2 0-11.2-5.5-14.3-17-12.3-8.2 1.4-185.7 34.6-185.7 34.6-10.2 2.2-13.4 5.2-13.4 16.7 0 234.7 1.1 223.9-2.5 239.5-4.2 18.2-15.4 31.9-30.2 39.5-16.8 9.3-47.2 13.4-63.4 10.4-43.2-8.1-58.4-58-29.1-86.6 17-16.2 40.9-19.5 76.8-25.8 6-1.1 11.2-2.5 15.6-7.4 10.1-11.5 1.8-256.6 5.2-270.2 .8-5.2 3-9.6 7.1-12.9 4.2-3.5 11.8-5.5 13.4-5.5 204-38.2 228.9-43.1 232.4-43.1 11.5-.8 18.1 6 18.1 17.6 .2 344.5 1.1 326-1.8 338.5z" />
                        </svg>
                    </div>

                    <h5 class="fw-semibold text-white mb-2">
                        @ViewData["NoResultSongs"]
                    </h5>

                    <p class="text-dark mb-4">
                        Get started by uploading your first track to the platform.
                    </p>
                </div>
            }
            else
            {
                <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 mx-auto justify-content-center" style="max-width: 1200px;">
                    @foreach (var song in Model.Singles)
                    {
                        <div class="col mb-4" id="song-@song.Id">
                            <div class="card h-100 border-0 shadow-sm song-card-container"
                                 style="border-radius: 12px; background-color: #1a1a1a; transition: transform 0.3s ease; overflow: visible;">

                                <div style="position: relative; width: 100%; padding-bottom: 100%; background-color: #2a2a2a; border-radius: 12px 12px 0 0; overflow: hidden;">
                                    <a asp-controller="Song" asp-action="Details" asp-route-id="@song.Id">
                                        <img src="@song.ImageURL"
                                             alt="@song.Title"
                                             style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                                    </a>
                                </div>

                                <div class="card-body p-3 d-flex flex-column">
                                    <div class="d-flex align-items-center justify-content-between w-100 mb-3">
                                        <div class="flex-grow-1 overflow-hidden">
                                            <h6 class="card-title mb-0 text-truncate text-white"
                                                title="@song.Title"
                                                style="font-weight: 700; font-size: 0.95rem;">
                                                @song.Title
                                            </h6>
                                        </div>

                                        <button class="btn p-0 play-btn-custom"
                                                type="button"
                                                data-song-id="@song.Id"
                                                onclick="loadSong('@song.Id')">
                                            <svg viewBox="0 0 640 640" height="40" width="40" style="background-color:transparent">
                                                <path fill="#ffc107" d="M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z" />
                                            </svg>
                                        </button>
                                    </div>

                                    <div class="mt-auto">
                                        @if (User.IsInRole("Artist"))
                                        {
                                            <div class="dropup">
                                                <button class="btn btn-sm w-100 d-flex align-items-center justify-content-center py-2"
                                                        type="button"
                                                        data-bs-toggle="dropdown"
                                                        aria-expanded="false"
                                                        style="background-color: rgba(255,255,255,0.07); color: #ffffff; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; font-weight: 600;">
                                                    <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" class="me-2">
                                                        <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
                                                    </svg>
                                                    Options
                                                </button>

                                                <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary" style="border-radius: 10px;">
                                                    <li class="dropdown-submenu">
                                                        <a class="dropdown-item dropdown-toggle d-flex align-items-center justify-content-between py-2 me-2" style="cursor: pointer;">
                                                            <div class="d-flex align-items-center">
                                                                <svg viewBox="0 0 512 512" width="16" height="16" class="me-2 text-warning">
                                                                    <path fill="currentColor" d="M0 190.9V437.7a48 48 0 0 0 48 48h416a48 48 0 0 0 48-48V190.9a48 48 0 0 0-48-48H312.4l-64-64H48a48 48 0 0 0-48 48zm448 32v192a32 32 0 0 1-32 32H96a32 32 0 0 1-32-32V222.9a32 32 0 0 1 32-32h320a32 32 0 0 1 32 32z" />
                                                                </svg>
                                                                <span>Add to Album</span>
                                                            </div>
                                                        </a>
                                                        <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary">
                                                            @if (Model.Albums != null && Model.Albums.Any())
                                                            {
                                                                foreach (var album in Model.Albums)
                                                                {
                                                                    <li>
                                                                        <form method="post" asp-controller="Song" asp-action="AddSongToAlbum">
                                                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#song-@song.Id" />
                                                                            <input type="hidden" name="songId" value="@song.Id" />
                                                                            <input type="hidden" name="albumId" value="@album.Id" />
                                                                            <button type="submit" class="dropdown-item py-2">@album.Title</button>
                                                                        </form>
                                                                    </li>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <li class="dropdown-item text-muted">No albums available</li>
                                                            }
                                                        </ul>
                                                    </li>

                                                    <li><hr class="dropdown-divider border-secondary" /></li>

                                                    <li>
                                                        <a asp-controller="Song" asp-action="Edit" asp-route-id="@song.Id" class="dropdown-item d-flex align-items-center py-2 text-warning" hx-boost="false">
                                                            <svg viewBox="0 0 512 512" width="16" height="16" class="me-2">
                                                                <path fill="orange" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z" />
                                                            </svg>
                                                            Edit Song
                                                        </a>
                                                    </li>

                                                    <li>
                                                        <form id="delete-form-@song.Id" asp-controller="Song" asp-action="Delete" method="post" asp-route-id="@song.Id" hx-boost="false">
                                                            <input type="hidden" name="sourceController" value="@ViewContext.RouteData.Values["controller"]" />
                                                            <input type="hidden" name="sourceAction" value="@ViewContext.RouteData.Values["action"]" />
                                                            <button type="button"
                                                                    class="dropdown-item d-flex align-items-center py-2 text-danger"
                                                                    onclick="confirmDelete(event, 'delete-form-@song.Id')">
                                                                <svg viewBox="0 0 448 512" width="16" height="16" class="me-2">
                                                                    <path fill="red" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                                                </svg>
                                                                Delete Song
                                                            </button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="tab-pane fade" id="pills-albums" role="tabpanel" aria-labelledby="pills-albums-tab">
            <div class="text-light text-center">
                <h3 class="fw-bold mb-3">
                    Your <span class="specific_heading">Albums</span>
                </h3>
            </div>

            @if (!Model.Albums.Any())
            {
                <div class="border border-secondary border-opacity-50 rounded-4 text-center py-5 px-3 mb-5 shadow-sm">
                    <div class="mb-3">
                        <svg viewBox="0 0 384 512" height="70" width="70">
                            <path fill="#ffc107" d="M381.9 388.2c-6.4 27.4-27.2 42.8-55.1 48-24.5 4.5-44.9 5.6-64.5-10.2-23.9-20.1-24.2-53.4-2.7-74.4 17-16.2 40.9-19.5 76.8-25.8 6-1.1 11.2-2.5 15.6-7.4 6.4-7.2 4.4-4.1 4.4-163.2 0-11.2-5.5-14.3-17-12.3-8.2 1.4-185.7 34.6-185.7 34.6-10.2 2.2-13.4 5.2-13.4 16.7 0 234.7 1.1 223.9-2.5 239.5-4.2 18.2-15.4 31.9-30.2 39.5-16.8 9.3-47.2 13.4-63.4 10.4-43.2-8.1-58.4-58-29.1-86.6 17-16.2 40.9-19.5 76.8-25.8 6-1.1 11.2-2.5 15.6-7.4 10.1-11.5 1.8-256.6 5.2-270.2 .8-5.2 3-9.6 7.1-12.9 4.2-3.5 11.8-5.5 13.4-5.5 204-38.2 228.9-43.1 232.4-43.1 11.5-.8 18.1 6 18.1 17.6 .2 344.5 1.1 326-1.8 338.5z" />
                        </svg>
                    </div>

                    <h5 class="fw-semibold text-white mb-2">
                        @ViewData["NoResultAlbums"]
                    </h5>

                    <p class="text-dark mb-4">
                        Get started by uploading your first album to the platform.
                    </p>
                </div>
            }
            else
            {
                <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 justify-content-center">
                    @foreach (var album in Model.Albums)
                    {
                        <div class="col" id="album-@album.Id">
                            <div class="card h-100 border-0 shadow-sm project-card"
                                 style="border-radius: 12px; background-color: #1a1a1a; transition: transform 0.3s ease; overflow: visible;">

                                <div class="card-img-top overflow-hidden" style="aspect-ratio: 1 / 1; background-color: #2a2a2a; border-radius: 12px 12px 0 0;">
                                    <a asp-controller="Album" asp-action="Details" asp-route-id="@album.Id">
                                        <img src="@album.ImageURL" alt="@album.Title" class="w-100 h-100" style="object-fit: cover;">
                                    </a>
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <div class="d-flex align-items-center justify-content-between w-100 mb-3">
                                        <div class="flex-grow-1 overflow-hidden">
                                            <h6 class="card-title mb-0 text-truncate text-white"
                                                title="@album.Title"
                                                style="font-weight: 700; font-size: 0.95rem;">
                                                @album.Title
                                            </h6>
                                        </div>

                                        <button class="btn p-0 play-btn-custom"
                                                type="button"
                                                onclick="loadSongsFromAlbumToQueue('@album.Id')">
                                            <svg viewBox="0 0 640 640" height="50" width="50" style="background-color:transparent">
                                                <path fill="#ffc107" d="M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z" />
                                            </svg>
                                        </button>
                                    </div>

                                    <div class="mb-3">
                                        @foreach (var artist in album.Artists)
                                        {
                                            <span class="badge" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3);">
                                                @artist
                                            </span>
                                        }
                                    </div>

                                    <div style="font-size: 0.85rem; color: #adb5bd;">
                                        <div class="d-flex align-items-center mb-2">
                                            <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm0 448c-110.5 0-200-89.5-200-200S145.5 56 256 56s200 89.5 200 200-89.5 200-200 200zm61.8-104.4l-84.9-61.7c-3.1-2.3-4.9-5.9-4.9-9.7V116c0-6.6 5.4-12 12-12h32c6.6 0 12 5.4 12 12v141.7l66.8 48.6c5.4 3.9 6.5 11.4 2.6 16.8L333.8 343c-3.9 5.3-11.4 6.4-16.8 2.6z" />
                                            </svg>
                                            <span><strong>Length:</strong> @album.Hours.ToString("D2"):@album.Minutes.ToString("D2"):@album.Seconds.ToString("D2")</span>
                                        </div>

                                        <div class="d-flex align-items-center mb-2">
                                            <svg viewBox="0 0 448 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M148 288h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v40c0-6.6-5.4-12-12-12zm108-52v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 96v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm192 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96-260v352c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V112c0-26.5 21.5-48 48-48h48V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h128V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h48c26.5 0 48 21.5 48 48zM400 464V192H48v272h352z" />
                                            </svg>
                                            <span><strong>Released:</strong> @album.ReleaseDate.ToString("dd MMM yyyy")</span>
                                        </div>

                                        <div class="d-flex align-items-center mb-3">
                                            <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M470.38 1.51L150.41 96A32 32 0 0 0 128 126.51v261.41A139 139 0 0 0 96 384c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V214.32l256-75v184.61a138.4 138.4 0 0 0-32-4c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V32a32 32 0 0 0-41.62-30.49z" />
                                            </svg>
                                            <span><strong>Songs:</strong> @album.SongsCount</span>
                                        </div>
                                    </div>

                                    @if (User.IsInRole("Artist"))
                                    {
                                        <div class="dropup mt-auto">
                                            <button class="btn btn-sm w-100 d-flex align-items-center justify-content-center py-2"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false"
                                                    style="background-color: rgba(255,255,255,0.07); color: #ffffff; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; font-weight: 600;">
                                                <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" class="me-2">
                                                    <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z" />
                                                </svg>
                                                Options
                                            </button>

                                            <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary" style="border-radius: 10px;">
                                                <li>
                                                    <a asp-controller="Album" asp-action="Edit" asp-route-id="@album.Id" class="dropdown-item d-flex align-items-center py-2 text-warning" hx-boost="false">
                                                        <svg viewBox="0 0 512 512" width="16" height="16" class="me-2">
                                                            <path fill="orange" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z" />
                                                        </svg>
                                                        Edit album
                                                    </a>
                                                </li>
                                                <li>
                                                    <form id="delete-form-@album.Id" asp-controller="Album" asp-action="Delete" method="post" asp-route-id="@album.Id" hx-boost="false">
                                                        <input type="hidden" name="sourceController" value="@ViewContext.RouteData.Values["controller"]" />
                                                        <input type="hidden" name="sourceAction" value="@ViewContext.RouteData.Values["action"]" />
                                                        <button type="button"
                                                                class="dropdown-item d-flex align-items-center py-2 text-danger"
                                                                onclick="confirmDelete(event, 'delete-form-@album.Id')">
                                                            <svg viewBox="0 0 448 512" width="16" height="16" class="me-2">
