@model MyProjectsViewModel

@{
    ViewData["Title"] = "My Projects";
}

<div class="container mt-4">

    <div class="container py-5">
        <div class="text-center text-light">
            <h1 class="display-4 fw-bold mb-3">
                My <span class="text-warning"> Music Projects</span>
            </h1>
            <p class="text-muted">Explore your projects and make new ones</p>
        </div>
    </div>

<div class="d-flex align-items-center gap-4 mb-4">
        <a asp-controller="Song" asp-action="Create" class="btn btn-warning btn-lg d-inline-flex align-items-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(0, 0, 0)" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM296 408L296 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296L296 296L296 232C296 218.7 306.7 208 320 208C333.3 208 344 218.7 344 232L344 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L344 344L344 408C344 421.3 333.3 432 320 432C306.7 432 296 421.3 296 408z" /></svg>Upload music
    </a>

        <a asp-controller="Album" asp-action="Create" class="btn btn-warning btn-lg d-inline-flex align-items-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(0, 0, 0)" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM296 408L296 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296L296 296L296 232C296 218.7 306.7 208 320 208C333.3 208 344 218.7 344 232L344 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L344 344L344 408C344 421.3 333.3 432 320 432C306.7 432 296 421.3 296 408z" /></svg>Upload album
    </a>
</div>

    <div class="text-light">
        <h4 class="display-4 fw-bold mb-3">
            My <span class="text-warning">Singles</span>
        </h4>
    </div>

    @if (!Model.Singles.Any())
    {
        <div class="alert alert-light border rounded-4 text-center fw-semibold shadow-sm fs-5 mb-5">
            <i class="bi bi-search me-2 text-muted"></i>
            @ViewData["NoResultSongs"]
        </div>
    }
    else
    {
        <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 mb-5">
            @foreach (var song in Model.Singles)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="@song.ImageURL" class="w-100 h-100" alt="@song.Title" style="object-fit:contain;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@song.Title</h5>
                            <p class="card-text mb-1"><strong>Genre:</strong> @song.GenreName</p>
                            @if (!string.IsNullOrEmpty(song.AlbumName))
                            {
                                <p class="card-text mb-1"><strong>Album:</strong> @song.AlbumName</p>
                            }
                            <p class="card-text mb-1">
                                <strong>Artists:</strong>
                                @foreach (var artist in song.Artists)
                                {
                                    <span class="badge bg-secondary me-1">@artist</span>
                                }
                            </p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M528 320C528 434.9 434.9 528 320 528C205.1 528 112 434.9 112 320C112 205.1 205.1 112 320 112C434.9 112 528 205.1 528 320zM64 320C64 461.4 178.6 576 320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320zM296 184L296 320C296 328 300 335.5 306.7 340L402.7 404C413.7 411.4 428.6 408.4 436 397.3C443.4 386.2 440.4 371.4 429.3 364L344 307.2L344 184C344 170.7 333.3 160 320 160C306.7 160 296 170.7 296 184z" /></svg><strong>Length:</strong> @song.Minutes.ToString("D2"):@song.Seconds.ToString("D2") minutes</p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M216 64C229.3 64 240 74.7 240 88L240 128L400 128L400 88C400 74.7 410.7 64 424 64C437.3 64 448 74.7 448 88L448 128L480 128C515.3 128 544 156.7 544 192L544 480C544 515.3 515.3 544 480 544L160 544C124.7 544 96 515.3 96 480L96 192C96 156.7 124.7 128 160 128L192 128L192 88C192 74.7 202.7 64 216 64zM216 176L160 176C151.2 176 144 183.2 144 192L144 240L496 240L496 192C496 183.2 488.8 176 480 176L216 176zM144 288L144 480C144 488.8 151.2 496 160 496L480 496C488.8 496 496 488.8 496 480L496 288L144 288z" /></svg><strong>Release Date:</strong> @song.ReleaseDate.ToString("dd MMM yyyy")</p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M442.9 144C415.6 144 389.9 157.1 373.9 179.2L339.5 226.8C335 233 327.8 236.7 320.1 236.7C312.4 236.7 305.2 233 300.7 226.8L266.3 179.2C250.3 157.1 224.6 144 197.3 144C150.3 144 112.2 182.1 112.2 229.1C112.2 279 144.2 327.5 180.3 371.4C221.4 421.4 271.7 465.4 306.2 491.7C309.4 494.1 314.1 495.9 320.2 495.9C326.3 495.9 331 494.1 334.2 491.7C368.7 465.4 419 421.3 460.1 371.4C496.3 327.5 528.2 279 528.2 229.1C528.2 182.1 490.1 144 443.1 144zM335 151.1C360 116.5 400.2 96 442.9 96C516.4 96 576 155.6 576 229.1C576 297.7 533.1 358 496.9 401.9C452.8 455.5 399.6 502 363.1 529.8C350.8 539.2 335.6 543.9 320 543.9C304.4 543.9 289.2 539.2 276.9 529.8C240.4 502 187.2 455.5 143.1 402C106.9 358.1 64 297.7 64 229.1C64 155.6 123.6 96 197.1 96C239.8 96 280 116.5 305 151.1L320 171.8L335 151.1z" /></svg><strong>Likes:</strong> @song.Likes</p>
                            @if (User.IsInRole("Artist"))
                            {
                                <div class="d-flex gap-2 align-items-center mt-1">
                                    <a asp-controller="Song" asp-action="Edit" asp-route-id="@song.Id" class="btn btn-warning btn-sm d-inline-flex align-items-center">
                                        <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                            <path fill="rgb(0, 0, 0)" d="M535.6 85.7C513.7 63.8 478.3 63.8 456.4 85.7L432 110.1L529.9 208L554.3 183.6C576.2 161.7 576.2 126.3 554.3 104.4L535.6 85.7zM236.4 305.7C230.3 311.8 225.6 319.3 222.9 327.6L193.3 416.4C190.4 425 192.7 434.5 199.1 441C205.5 447.5 215 449.7 223.7 446.8L312.5 417.2C320.7 414.5 328.2 409.8 334.4 403.7L496 241.9L398.1 144L236.4 305.7zM160 128C107 128 64 171 64 224L64 480C64 533 107 576 160 576L416 576C469 576 512 533 512 480L512 384C512 366.3 497.7 352 480 352C462.3 352 448 366.3 448 384L448 480C448 497.7 433.7 512 416 512L160 512C142.3 512 128 497.7 128 480L128 224C128 206.3 142.3 192 160 192L256 192C273.7 192 288 177.7 288 160C288 142.3 273.7 128 256 128L160 128z" />
                                        </svg>
                                        Edit
                                    </a>

                                    <form asp-controller="Song" asp-action="Delete" method="post" asp-route-id="@song.Id">
                                        <button class="btn btn-danger btn-sm d-inline-flex align-items-center">
                                            <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                                <path fill="rgb(0, 0, 0)" d="M232.7 69.9L224 96L128 96C110.3 96 96 110.3 96 128C96 145.7 110.3 160 128 160L512 160C529.7 160 544 145.7 544 128C544 110.3 529.7 96 512 96L416 96L407.3 69.9C402.9 56.8 390.7 48 376.9 48L263.1 48C249.3 48 237.1 56.8 232.7 69.9zM512 208L128 208L149.1 531.1C150.7 556.4 171.7 576 197 576L443 576C468.3 576 489.3 556.4 490.9 531.1L512 208z" />
                                            </svg>
                                            Delete
                                        </button>
                                    </form>

                                    <div class="dropup">
                                        <button class="btn btn-sm btn-secondary dropdown-toggle"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false">
                                            <svg viewBox="0 0 640 640" width="25" height="25"><path fill="rgb(255, 255, 255)" d="M96 320C96 289.1 121.1 264 152 264C182.9 264 208 289.1 208 320C208 350.9 182.9 376 152 376C121.1 376 96 350.9 96 320zM264 320C264 289.1 289.1 264 320 264C350.9 264 376 289.1 376 320C376 350.9 350.9 376 320 376C289.1 376 264 350.9 264 320zM488 264C518.9 264 544 289.1 544 320C544 350.9 518.9 376 488 376C457.1 376 432 350.9 432 320C432 289.1 457.1 264 488 264z" /></svg>
                                        </button>

                                        <ul class="dropdown-menu">

                                            <li class="dropdown-submenu">
                                                <a class="dropdown-item dropdown-toggle">Add to Album</a>

                                                <ul class="dropdown-menu">
                                                    @if (Model.Albums != null && Model.Albums.Any())
                                                    {
                                                        @foreach (var album in Model.Albums)
                                                        {
                                                            <form method="post" asp-controller="Song" asp-action="AddSongToAlbum">
                                                                <input type="hidden" name="songId" value="@song.Id" />
                                                                <input type="hidden" name="albumId" value="@album.Id" />
                                                                <button type="submit" class="dropdown-item">@album.Title</button>
                                                            </form>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <li class="dropdown-item text-muted">No playlists</li>
                                                    }
                                                </ul>
                                            </li>
                                        </ul>
                                    </div>

                                </div>

                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="text-light">
        <h4 class="display-4 fw-bold mb-3">
            My <span class="text-warning">Albums</span>
        </h4>
    </div>

    @if (!Model.Albums.Any())
    {
        <div class="alert alert-light border rounded-4 text-center fw-semibold shadow-sm fs-5 mb-5">
            <i class="bi bi-search me-2 text-muted"></i>
            @ViewData["NoResultAlbums"]
        </div>
    }
    else
    {
        <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4">
            @foreach (var album in Model.Albums)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-img-top overflow-hidden" style="aspect-ratio: 1 / 1;">
                            <img src="@album.ImageURL"
                                 alt="@album.Title"
                                 class="w-100 h-100"
                                 style="object-fit: contain;">
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@album.Title</h5>
                            <p class="card-text mb-1">
                                <strong>Artists:</strong>
                                @foreach (var artist in album.Artists)
                                {
                                    <span class="badge bg-secondary me-1">@artist</span>
                                }
                            </p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M528 320C528 434.9 434.9 528 320 528C205.1 528 112 434.9 112 320C112 205.1 205.1 112 320 112C434.9 112 528 205.1 528 320zM64 320C64 461.4 178.6 576 320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320zM296 184L296 320C296 328 300 335.5 306.7 340L402.7 404C413.7 411.4 428.6 408.4 436 397.3C443.4 386.2 440.4 371.4 429.3 364L344 307.2L344 184C344 170.7 333.3 160 320 160C306.7 160 296 170.7 296 184z" /></svg><strong>Length:</strong> @album.Hours.ToString("D2"):@album.Minutes.ToString("D2"):@album.Seconds.ToString("D2")</p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M216 64C229.3 64 240 74.7 240 88L240 128L400 128L400 88C400 74.7 410.7 64 424 64C437.3 64 448 74.7 448 88L448 128L480 128C515.3 128 544 156.7 544 192L544 480C544 515.3 515.3 544 480 544L160 544C124.7 544 96 515.3 96 480L96 192C96 156.7 124.7 128 160 128L192 128L192 88C192 74.7 202.7 64 216 64zM216 176L160 176C151.2 176 144 183.2 144 192L144 240L496 240L496 192C496 183.2 488.8 176 480 176L216 176zM144 288L144 480C144 488.8 151.2 496 160 496L480 496C488.8 496 496 488.8 496 480L496 288L144 288z" /></svg><strong>Release Date:</strong> @album.ReleaseDate.ToString("dd MMM yyyy")</p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M532 71C539.6 77.1 544 86.3 544 96L544 400C544 444.2 501 480 448 480C395 480 352 444.2 352 400C352 355.8 395 320 448 320C459.2 320 470 321.6 480 324.6L480 207.9L256 257.7L256 464C256 508.2 213 544 160 544C107 544 64 508.2 64 464C64 419.8 107 384 160 384C171.2 384 182 385.6 192 388.6L192 160C192 145 202.4 132 217.1 128.8L505.1 64.8C514.6 62.7 524.5 65 532.1 71.1z" /></svg><strong>Songs Count:</strong> @album.SongsCount</p>
                            @if (User.IsInRole("Artist"))
                            {
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-controller="Album" asp-action="Edit" asp-route-id="@album.Id" class="btn btn-warning btn-sm d-inline-flex align-items-center">
                                        <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                            <path fill="rgb(0, 0, 0)" d="M535.6 85.7C513.7 63.8 478.3 63.8 456.4 85.7L432 110.1L529.9 208L554.3 183.6C576.2 161.7 576.2 126.3 554.3 104.4L535.6 85.7zM236.4 305.7C230.3 311.8 225.6 319.3 222.9 327.6L193.3 416.4C190.4 425 192.7 434.5 199.1 441C205.5 447.5 215 449.7 223.7 446.8L312.5 417.2C320.7 414.5 328.2 409.8 334.4 403.7L496 241.9L398.1 144L236.4 305.7zM160 128C107 128 64 171 64 224L64 480C64 533 107 576 160 576L416 576C469 576 512 533 512 480L512 384C512 366.3 497.7 352 480 352C462.3 352 448 366.3 448 384L448 480C448 497.7 433.7 512 416 512L160 512C142.3 512 128 497.7 128 480L128 224C128 206.3 142.3 192 160 192L256 192C273.7 192 288 177.7 288 160C288 142.3 273.7 128 256 128L160 128z" />
                                        </svg>
                                        Edit
                                    </a>

                                    <form asp-controller="Album" asp-action="Delete" method="post" asp-route-id="@album.Id">
                                        <button class="btn btn-danger btn-sm d-inline-flex align-items-center">
                                            <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                                <path fill="rgb(0, 0, 0)" d="M232.7 69.9L224 96L128 96C110.3 96 96 110.3 96 128C96 145.7 110.3 160 128 160L512 160C529.7 160 544 145.7 544 128C544 110.3 529.7 96 512 96L416 96L407.3 69.9C402.9 56.8 390.7 48 376.9 48L263.1 48C249.3 48 237.1 56.8 232.7 69.9zM512 208L128 208L149.1 531.1C150.7 556.4 171.7 576 197 576L443 576C468.3 576 489.3 556.4 490.9 531.1L512 208z" />
                                            </svg>
                                            Delete
                                        </button>
                                    </form>
                                    <a asp-controller="Album" asp-action="Details" asp-route-id="@album.Id" class="btn btn-info btn-sm d-inline-flex align-items-center">
                                        <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                            <path fill="rgb(0, 0, 0)" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM288 224C288 206.3 302.3 192 320 192C337.7 192 352 206.3 352 224C352 241.7 337.7 256 320 256C302.3 256 288 241.7 288 224zM280 288L328 288C341.3 288 352 298.7 352 312L352 400L360 400C373.3 400 384 410.7 384 424C384 437.3 373.3 448 360 448L280 448C266.7 448 256 437.3 256 424C256 410.7 266.7 400 280 400L304 400L304 336L280 336C266.7 336 256 325.3 256 312C256 298.7 266.7 288 280 288z" />
                                        </svg>
                                        Details
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>