@model MyProjectsViewModel

@{
    ViewData["Title"] = "My Projects";
}

<div class="container mt-4">

    <div class="container py-5">
        <div class="text-center text-light">
            <h1 class="display-4 fw-bold mb-3">
                My <span class="text-warning"> Music Projects</span>
            </h1>
            <p class="text-muted">Explore your projects and make new ones</p>
        </div>
    </div>

<div class="d-flex align-items-center gap-4 mb-4">
        <a asp-controller="Song" asp-action="Create" class="btn btn-warning btn-lg d-inline-flex align-items-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(0, 0, 0)" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM296 408L296 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296L296 296L296 232C296 218.7 306.7 208 320 208C333.3 208 344 218.7 344 232L344 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L344 344L344 408C344 421.3 333.3 432 320 432C306.7 432 296 421.3 296 408z" /></svg>Upload music
    </a>

        <a asp-controller="Album" asp-action="Create" class="btn btn-warning btn-lg d-inline-flex align-items-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(0, 0, 0)" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM296 408L296 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296L296 296L296 232C296 218.7 306.7 208 320 208C333.3 208 344 218.7 344 232L344 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L344 344L344 408C344 421.3 333.3 432 320 432C306.7 432 296 421.3 296 408z" /></svg>Upload album
    </a>
</div>

    <hr />
    <div class="text-light">
        <h4 class="display-4 fw-bold mb-3">
            My <span class="text-warning">Singles</span>
        </h4>
    </div>

    @if (!Model.Singles.Any())
    {
        <div class="alert alert-light border rounded-4 text-center fw-semibold shadow-sm fs-5 mb-5">
            <i class="bi bi-search me-2 text-muted"></i>
            @ViewData["NoResultSongs"]
        </div>
    }
    else
    {
        <div class="container my-5">
            <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 mx-auto"
                 style="max-width: 1200px;">

                @foreach (var song in Model.Singles)
                {
                    <div class="col mb-4">
                        <div class="card h-100 shadow-sm border-0 overflow-hidden" style="transition: transform 0.2s; border-radius: 12px;">

                            <div style="position: relative; width: 100%; padding-bottom: 100%; background-color: #f8f9fa; border-radius: 12px 12px 0 0; overflow: hidden;">
                                <a asp-controller="Song" asp-action="Details">
                                    <img src="@song.ImageURL"
                                         alt="@song.Title"
                                         style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain;">
                                </a>
                            </div>

                            <div class="card-body p-3 d-flex flex-column">
                                <h6 class="card-title mb-1 text-truncate" title="@song.Title" style="font-weight: 700; font-size: 0.9rem;">
                                    @song.Title
                                </h6>

                                <div class="mt-auto">
                                    @if (User.IsInRole("Artist"))
                                    {
                                        <div class="dropup mt-auto">
                                            <button class="btn btn-sm btn-secondary dropdown-toggle"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false">
                                                <svg viewBox="0 0 640 640" width="18" height="18" class="me-2">
                                                    <path fill="rgb(255, 255, 255)" d="M96 320C96 289.1 121.1 264 152 264C182.9 264 208 289.1 208 320C208 350.9 182.9 376 152 376C121.1 376 96 350.9 96 320zM264 320C264 289.1 289.1 264 320 264C350.9 264 376 289.1 376 320C376 350.9 350.9 376 320 376C289.1 376 264 350.9 264 320zM488 264C518.9 264 544 289.1 544 320C544 350.9 518.9 376 488 376C457.1 376 432 350.9 432 320C432 289.1 457.1 264 488 264z" />
                                                </svg>
                                            </button>

                                            <ul class="dropdown-menu dropdown-menu-dark shadow">
                                                <li class="dropdown-submenu">
                                                    <a class="dropdown-item dropdown-toggle d-flex align-items-center justify-content-between py-2 w-100"
                                                       style="cursor: pointer;">
                                                        <div class="d-flex align-items-center">
                                                            <svg viewBox="0 0 448 512" width="18" height="18" class="me-2">
                                                                <path fill="rgb(255, 255, 255)" d="M64 80c-8.8 0-16 7.2-16 16l0 320c0 8.8 7.2 16 16 16l320 0c8.8 0 16-7.2 16-16l0-320c0-8.8-7.2-16-16-16L64 80zM0 96C0 60.7 28.7 32 64 32l320 0c35.3 0 64 28.7 64 64l0 320c0 35.3-28.7 64-64 64L64 480c-35.3 0-64-28.7-64-64L0 96zM200 344l0-64-64 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l64 0 0-64c0-13.3 10.7-24 24-24s24 10.7 24 24l0 64 64 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-64 0 0 64c0 13.3-10.7 24-24 24s-24-10.7-24-24z" />
                                                            </svg>
                                                            <span>Add to Album</span>
                                                        </div>
                                                    </a>
                                                    <ul class="dropdown-menu dropdown-menu-dark shadow">
                                                        @if (Model.Albums != null && Model.Albums.Any())
                                                        {
                                                            foreach (var album in Model.Albums)
                                                            {
                                                                <li>
                                                                    <form method="post" asp-controller="Song" asp-action="AddSongToAlbum">
                                                                        <input type="hidden" name="songId" value="@song.Id" />
                                                                        <input type="hidden" name="albumId" value="@album.Id" />
                                                                        <button type="submit" class="dropdown-item">@album.Title</button>
                                                                    </form>
                                                                </li>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <li class="dropdown-item text-muted">No albums available</li>
                                                        }
                                                    </ul>
                                                </li>

                                                <li><hr class="dropdown-divider" /></li>

                                                <li>
                                                    <a asp-controller="Song" asp-action="Edit" asp-route-id="@song.Id"
                                                       class="dropdown-item d-flex align-items-center py-2">
                                                        <svg viewBox="0 0 512 512" width="18" height="18" class="me-2">
                                                            <path fill="rgb(255, 212, 59)" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z" />
                                                        </svg>
                                                        Edit Song
                                                    </a>
                                                </li>

                                                <li>
                                                    <form asp-controller="Song" asp-action="Delete" method="post" asp-route-id="@song.Id" id="deleteForm-@song.Id">
                                                        <button type="submit" class="dropdown-item d-flex align-items-center py-2"
                                                                onclick="return confirm('Are you sure you want to delete this song?');">
                                                            <svg viewBox="0 0 448 512" width="18" height="18" class="me-2">
                                                                <path fill="rgb(255, 0, 0)" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                                            </svg>
                                                            Delete Song
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <hr />
    <div class="text-light">
        <h4 class="display-4 fw-bold mb-3">
            My <span class="text-warning">Albums</span>
        </h4>
    </div>

    @if (!Model.Albums.Any())
    {
        <div class="alert alert-light border rounded-4 text-center fw-semibold shadow-sm fs-5 mb-5">
            <i class="bi bi-search me-2 text-muted"></i>
            @ViewData["NoResultAlbums"]
        </div>
    }
    else
    {
        <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4">
            @foreach (var album in Model.Albums)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-img-top overflow-hidden" style="aspect-ratio: 1 / 1;">
                            <a asp-controller="Album" asp-action="Details" asp-route-id="@album.Id">
                                <img src="@album.ImageURL"
                                     alt="@album.Title"
                                     class="w-100 h-100"
                                     style="object-fit: contain;">
                            </a>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@album.Title</h5>
                            <p class="card-text mb-1">
                                <strong>Artists:</strong>
                                @foreach (var artist in album.Artists)
                                {
                                    <span class="badge bg-secondary me-1">@artist</span>
                                }
                            </p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M528 320C528 434.9 434.9 528 320 528C205.1 528 112 434.9 112 320C112 205.1 205.1 112 320 112C434.9 112 528 205.1 528 320zM64 320C64 461.4 178.6 576 320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320zM296 184L296 320C296 328 300 335.5 306.7 340L402.7 404C413.7 411.4 428.6 408.4 436 397.3C443.4 386.2 440.4 371.4 429.3 364L344 307.2L344 184C344 170.7 333.3 160 320 160C306.7 160 296 170.7 296 184z" /></svg><strong>Length:</strong> @album.Hours.ToString("D2"):@album.Minutes.ToString("D2"):@album.Seconds.ToString("D2")</p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M216 64C229.3 64 240 74.7 240 88L240 128L400 128L400 88C400 74.7 410.7 64 424 64C437.3 64 448 74.7 448 88L448 128L480 128C515.3 128 544 156.7 544 192L544 480C544 515.3 515.3 544 480 544L160 544C124.7 544 96 515.3 96 480L96 192C96 156.7 124.7 128 160 128L192 128L192 88C192 74.7 202.7 64 216 64zM216 176L160 176C151.2 176 144 183.2 144 192L144 240L496 240L496 192C496 183.2 488.8 176 480 176L216 176zM144 288L144 480C144 488.8 151.2 496 160 496L480 496C488.8 496 496 488.8 496 480L496 288L144 288z" /></svg><strong>Release Date:</strong> @album.ReleaseDate.ToString("dd MMM yyyy")</p>
                            <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M532 71C539.6 77.1 544 86.3 544 96L544 400C544 444.2 501 480 448 480C395 480 352 444.2 352 400C352 355.8 395 320 448 320C459.2 320 470 321.6 480 324.6L480 207.9L256 257.7L256 464C256 508.2 213 544 160 544C107 544 64 508.2 64 464C64 419.8 107 384 160 384C171.2 384 182 385.6 192 388.6L192 160C192 145 202.4 132 217.1 128.8L505.1 64.8C514.6 62.7 524.5 65 532.1 71.1z" /></svg><strong>Songs Count:</strong> @album.SongsCount</p>
                            @if (User.IsInRole("Artist"))
                            {
                                <div class="dropup mt-auto">
                                    <button class="btn btn-md btn-secondary dropdown-toggle"
                                            type="button"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                        <svg viewBox="0 0 640 640" width="18" height="18" class="me-2">
                                            <path fill="rgb(255, 255, 255)" d="M96 320C96 289.1 121.1 264 152 264C182.9 264 208 289.1 208 320C208 350.9 182.9 376 152 376C121.1 376 96 350.9 96 320zM264 320C264 289.1 289.1 264 320 264C350.9 264 376 289.1 376 320C376 350.9 350.9 376 320 376C289.1 376 264 350.9 264 320zM488 264C518.9 264 544 289.1 544 320C544 350.9 518.9 376 488 376C457.1 376 432 350.9 432 320C432 289.1 457.1 264 488 264z" />
                                        </svg>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-dark shadow">
                                        <li>
                                            <a asp-controller="Album" asp-action="Edit" asp-route-id="@album.Id" class="dropdown-item d-flex align-items-center py-2">
                                                <svg viewBox="0 0 512 512" width="18" height="18" class="me-2">
                                                    <path fill="rgb(255, 212, 59)" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z" />
                                                </svg>
                                                Edit album
                                            </a>
                                        </li>
                                        <li>
                                            <form asp-controller="Album" asp-action="Delete" method="post" asp-route-id="@album.Id">
                                                <button class="dropdown-item d-flex align-items-center py-2" onclick="return confirm('Are you sure you want to delete this album?');">
                                                    <svg viewBox="0 0 448 512" width="18" height="18" class="me-2">
                                                        <path fill="rgb(255, 0, 0)" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                                    </svg>
                                                    Delete album
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>