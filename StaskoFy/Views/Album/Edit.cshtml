@model AlbumEditViewModel

<div class="container py-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card shadow-lg border-0 rounded-4 album-create-edit-card ">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4 fw-bold">
                        Edit <span class="text-warning">Album</span>
                    </h2>

                    <form method="post" asp-action="Edit" enctype="multipart/form-data">
                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label fw-semibold">Album Title</label>
                                    <input asp-for="Title" class="form-control" placeholder="Title">
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ImageFile" class="form-label fw-semibold">Art Cover</label>
                                    <input type="file" asp-for="ImageFile" class="form-control" />
                                </div>

                                <div class="mb-3 mb-lg-4">
                                    <label asp-for="ReleaseDate" class="form-label fw-semibold">Release Date</label>
                                    <input asp-for="ReleaseDate" class="form-control" placeholder="Release Date">
                                    <span asp-validation-for="ReleaseDate" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6">
                                <div class="mb-3">
                                    <select asp-for="@Model.SelectedArtistIds"
                                            asp-items="Model.Artists"
                                            multiple
                                            class="form-select js-choice"
                                            data-choices
                                            data-remove-item-button="true"
                                            data-search-enabled="true"
                                            data-placeholder-value="Select artists"
                                            data-max-item-count="4"
                                            data-msg-maxlength="You can only select 4 featured artists.">
                                        @foreach (var artist in ViewBag.AllArtists)
                                        {
                                            bool isSelected = Model.SelectedArtistIds.Contains(artist.Id);
                                            <option value="@artist.Id" selected="@(isSelected ? "selected" : null)">
                                                @artist.Username
                                            </option>
                                        }
                                    </select>
                                    <span asp-validation-for="SelectedArtistIds" class="text-danger small"></span>
                                </div>

                                <div class="mb-3 mb-lg-0">
                                    <label class="form-label fw-semibold">Add More Songs</label>
                                    <select asp-for="SelectedSongIds"
                                            asp-items="Model.Songs"
                                            multiple
                                            class="form-select js-choice"
                                            data-choices
                                            data-remove-item-button="true"
                                            data-search-enabled="true"
                                            data-placeholder-value="Select songs"
                                            data-no-results-text="No songs found"
                                            data-item-select-text="Click to select"
                                            data-should-sort="false">
                                    </select>
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                                    <button type="submit" class="btn btn-warning btn-lg rounded-4 px-5 shadow fw-semibold">
                                        Save Changes
                                    </button>
                                    <a asp-controller="Library" asp-action="MyProjectsIndex" 
                                       class="btn btn-outline-warning btn-lg rounded-4 px-4">
                                        Cancel
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}