@model AlbumsPaginationViewModel

<style>
    /* Pagination Warning Theme */
    
</style>

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">
        Discover <span class="specific_heading">Albums</span>
    </h1>
    @if (User.IsInRole("Admin"))
    {
        <p class="text-muted">Browse all albums on the platform and <span class="text-danger">remove</span> any that <span class="text-danger">violate the rules</span>.</p>
    }
    else
    {
        <p class="text-muted">Explore all albums on the platform</p>
    }
</div>

<div class="row justify-content-center w-100 mx-0">
    <div class="col-12 col-md-8 col-lg-6 mb-4 mx-auto">
        <form asp-controller="Album" asp-action="AlbumsIndexForAllUsers" method="get">
            <div class="d-flex align-items-center gap-4 mb-4">
                <input class="form-control form-control-lg"
                       type="search"
                       placeholder="Search albums..."
                       name="searchItem"
                       value="@Context.Request.Query["searchItem"]" />
                <button type="submit" class="btn btn-search btn-lg d-inline-flex align-items-center px-4">
                    <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                    </svg>
                    Search
                </button>
            </div>
            <div class="d-flex align-items-center justify-content-center gap-4">
                <div>
                    <input type="radio" class="btn-check" id="filter-title" autocomplete="off" name="filters" value="Title"
                    @(Context.Request.Query["filters"] == "Title" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-title">By Title</label>
                </div>
                <div>
                    <input type="radio" class="btn-check" id="filter-artist" autocomplete="off" name="filters" value="Artist"
                    @(Context.Request.Query["filters"] == "Artist" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-artist">By Artist</label>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Albums.Any())
{
    <div class="alert alert-danger rounded-4 text-center fw-semibold shadow-sm fs-3">
        <i class="bi bi-search me-2"></i>
        @ViewData["NoResult"]
    </div>
}
else
{
    <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 justify-content-center">
        @foreach (var album in Model.Albums)
        {
            <div class="col">
                <div class="card h-100 shadow-sm song-card-container">
                    <div class="card-img-top overflow-hidden" style="aspect-ratio: 1 / 1;">
                        <a asp-action="Details" asp-route-id="@album.Id">
                            <img src="@album.ImageURL"
                                 alt="@album.Title"
                                 class="w-100 h-100"
                                 style="object-fit: contain;">
                        </a>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@album.Title</h5>
                        <p class="card-text mb-1">
                            <strong>Artists:</strong>
                            @foreach (var artist in album.Artists)
                            {
                                <span class="badge bg-secondary me-1">@artist</span>
                            }
                        </p>
                        <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M528 320C528 434.9 434.9 528 320 528C205.1 528 112 434.9 112 320C112 205.1 205.1 112 320 112C434.9 112 528 205.1 528 320zM64 320C64 461.4 178.6 576 320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320zM296 184L296 320C296 328 300 335.5 306.7 340L402.7 404C413.7 411.4 428.6 408.4 436 397.3C443.4 386.2 440.4 371.4 429.3 364L344 307.2L344 184C344 170.7 333.3 160 320 160C306.7 160 296 170.7 296 184z" /></svg><strong>Length:</strong> @album.Hours.ToString("D2"):@album.Minutes.ToString("D2"):@album.Seconds.ToString("D2")</p>
                        <p class="card-text mb-1"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M216 64C229.3 64 240 74.7 240 88L240 128L400 128L400 88C400 74.7 410.7 64 424 64C437.3 64 448 74.7 448 88L448 128L480 128C515.3 128 544 156.7 544 192L544 480C544 515.3 515.3 544 480 544L160 544C124.7 544 96 515.3 96 480L96 192C96 156.7 124.7 128 160 128L192 128L192 88C192 74.7 202.7 64 216 64zM216 176L160 176C151.2 176 144 183.2 144 192L144 240L496 240L496 192C496 183.2 488.8 176 480 176L216 176zM144 288L144 480C144 488.8 151.2 496 160 496L480 496C488.8 496 496 488.8 496 480L496 288L144 288z" /></svg><strong>Release Date:</strong> @album.ReleaseDate.ToString("dd MMM yyyy")</p>
                        <p class="card-text mb-2"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M532 71C539.6 77.1 544 86.3 544 96L544 400C544 444.2 501 480 448 480C395 480 352 444.2 352 400C352 355.8 395 320 448 320C459.2 320 470 321.6 480 324.6L480 207.9L256 257.7L256 464C256 508.2 213 544 160 544C107 544 64 508.2 64 464C64 419.8 107 384 160 384C171.2 384 182 385.6 192 388.6L192 160C192 145 202.4 132 217.1 128.8L505.1 64.8C514.6 62.7 524.5 65 532.1 71.1z" /></svg><strong>Songs Count:</strong> @album.SongsCount</p>
                        @if (User.IsInRole("Admin"))
                        {
                            <form asp-controller="Album" asp-action="Delete" method="post" asp-route-id="@album.Id">
                                <button class="btn btn-outline-danger btn-sm w-100 py-1" style="border-radius: 6px;"
                                        onclick="return confirm('Are you sure you want to delete this song?');">
                                    <svg viewBox="0 0 448 512" width="15" height="15" class="me-2">
                                        <path fill="currentColor" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                    </svg>Delete
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="d-flex justify-content-center mt-4">
    <nav>
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-pageSize="3">Previous</a>
                </li>
            }

            @if (Model.CurrentPage > 2)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="1" asp-route-pageSize="3">1</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            @for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
            {
                if (i > 0 && i <= Model.TotalPages)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@i" asp-route-pageSize="3">@i</a>
                    </li>
                }
            }

            @if (Model.CurrentPage < Model.TotalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="3">@Model.TotalPages</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-pageSize="3">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>