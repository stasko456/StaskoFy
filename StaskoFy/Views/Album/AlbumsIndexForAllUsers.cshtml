@model AlbumsPaginationViewModel

<style>
    /* Pagination Warning Theme */
    
</style>

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">
        Discover <span class="specific_heading">Albums</span>
    </h1>
    @if (User.IsInRole("Admin"))
    {
        <p class="text-muted">Browse all albums on the platform and <span class="text-danger">remove</span> any that <span class="text-danger">violate the rules</span>.</p>
    }
    else
    {
        <p class="text-muted">Explore all albums on the platform</p>
    }
</div>

<div class="row justify-content-center w-100 mx-0">
    <div class="col-12 col-md-8 col-lg-6 mb-4 mx-auto">
        <form asp-controller="Album" asp-action="AlbumsIndexForAllUsers" method="get">
            <div class="d-flex align-items-center gap-4 mb-4">
                <input class="form-control form-control-lg"
                       type="search"
                       placeholder="Search albums..."
                       name="searchItem"
                       value="@Context.Request.Query["searchItem"]" />
                <button type="submit" class="btn btn-search btn-lg d-inline-flex align-items-center px-4">
                    <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                    </svg>
                    Search
                </button>
            </div>
            <div class="d-flex align-items-center justify-content-center gap-4">
                <div>
                    <input type="radio" class="btn-check" id="filter-title" autocomplete="off" name="filters" value="Title"
                    @(Context.Request.Query["filters"] == "Title" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-title">By Title</label>
                </div>
                <div>
                    <input type="radio" class="btn-check" id="filter-artist" autocomplete="off" name="filters" value="Artist"
                    @(Context.Request.Query["filters"] == "Artist" ? "checked" : "") />
                    <label class="btn btn-outline-warning fw-bold px-4" for="filter-artist">By Artist</label>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Albums.Any())
{
    <div class="alert alert-danger rounded-4 text-center fw-semibold shadow-sm fs-3">
        <i class="bi bi-search me-2"></i>
        @ViewData["NoResult"]
    </div>
}
else
{
    <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 justify-content-center">
        @foreach (var album in Model.Albums)
        {
            <div class="col">
                <div class="card h-100 shadow-sm song-card-container border-0"
                     style="border-radius: 12px; background-color: #1a1a1a; transition: transform 0.3s ease; overflow: hidden;">

                    <div class="position-relative overflow-hidden" style="aspect-ratio: 1 / 1; background-color: #2a2a2a;">
                        <a asp-action="Details" asp-route-id="@album.Id">
                            <img src="@album.ImageURL"
                                 alt="@album.Title"
                                 class="w-100 h-100"
                                 style="object-fit: cover;">
                        </a>
                    </div>

                    <div class="card-body d-flex flex-column p-3">
                        <h5 class="card-title text-white mb-2 text-truncate" style="font-weight: 700; font-size: 1.1rem;" title="@album.Title">
                            @album.Title
                        </h5>

                        <div class="mb-3">
                            @foreach (var artist in album.Artists)
                            {
                                <span class="badge" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3);">
                                    @artist
                                </span>
                            }
                        </div>

                        <div class="album-info-list" style="font-size: 0.85rem; color: #adb5bd;">

                            <div class="d-flex align-items-center mb-2">
                                <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                    <path fill="currentColor" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm0 448c-110.5 0-200-89.5-200-200S145.5 56 256 56s200 89.5 200 200-89.5 200-200 200zm61.8-104.4l-84.9-61.7c-3.1-2.3-4.9-5.9-4.9-9.7V116c0-6.6 5.4-12 12-12h32c6.6 0 12 5.4 12 12v141.7l66.8 48.6c5.4 3.9 6.5 11.4 2.6 16.8L333.8 343c-3.9 5.3-11.4 6.4-16.8 2.6z" />
                                </svg>
                                <span><strong>Length:</strong> @album.Hours.ToString("D2"):@album.Minutes.ToString("D2"):@album.Seconds.ToString("D2")</span>
                            </div>

                            <div class="d-flex align-items-center mb-2">
                                <svg viewBox="0 0 448 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                    <path fill="currentColor" d="M148 288h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v40c0-6.6-5.4-12-12-12zm108-52v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 96v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm192 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96-260v352c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V112c0-26.5 21.5-48 48-48h48V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h128V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h48c26.5 0 48 21.5 48 48zM400 464V192H48v272h352z" />
                                </svg>
                                <span><strong>Released:</strong> @album.ReleaseDate.ToString("dd MMM yyyy")</span>
                            </div>

                            <div class="d-flex align-items-center mb-3">
                                <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                    <path fill="currentColor" d="M470.38 1.51L150.41 96A32 32 0 0 0 128 126.51v261.41A139 139 0 0 0 96 384c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V214.32l256-75v184.61a138.4 138.4 0 0 0-32-4c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V32a32 32 0 0 0-41.62-30.49z" />
                                </svg>
                                <span><strong>Songs:</strong> @album.SongsCount</span>
                            </div>
                        </div>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="mt-auto">
                                <form id="delete-form-@album.Id" asp-controller="Album" asp-action="Delete" method="post" asp-route-id="@album.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="sourceController" value="@ViewContext.RouteData.Values["controller"]" />
                                    <input type="hidden" name="sourceAction" value="@ViewContext.RouteData.Values["action"]" />
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm w-100 py-2 d-flex align-items-center justify-content-center"
                                            style="border-radius: 8px; font-weight: 600;"
                                            onclick="confirmDelete(event, 'delete-form-@album.Id')">
                                        <svg viewBox="0 0 448 512" width="14" height="14" class="me-2">
                                            <path fill="currentColor" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                        </svg>Delete Album
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="d-flex justify-content-center mt-4">
    <nav>
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-pageSize="3">Previous</a>
                </li>
            }

            @if (Model.CurrentPage > 2)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="1" asp-route-pageSize="3">1</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            @for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
            {
                if (i > 0 && i <= Model.TotalPages)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@i" asp-route-pageSize="3">@i</a>
                    </li>
                }
            }

            @if (Model.CurrentPage < Model.TotalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="3">@Model.TotalPages</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="AlbumsIndexForAllUsers" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-pageSize="3">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>