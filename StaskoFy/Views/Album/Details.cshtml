@model AlbumSongsIndexViewModel

@{
    var currentUserId = Guid.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier));
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
                    
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex flex-column flex-lg-row align-items-center align-items-lg-start gap-4 mb-5">

                        <!-- Album Image -->
                        <img src="@Model.ImageURL"
                             alt="@Model.Title"
                             class="rounded-4 shadow flex-shrink-0"
                             style="width:300px; height:300px; object-fit:cover;">

                        <!-- Album Info -->
                        <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center text-center" style="min-height:300px;">

                            <h2 class="fw-bold">
                                <i class="bi bi-disc"></i>
                                <span class="text-warning">@Model.Title</span>
                            </h2>

                            <p class="text-muted fw-bold fs-6 mb-2">
                                @Model.SongsCount songs •
                                @Model.Hours.ToString("D2"):
                                @Model.Minutes.ToString("D2"):
                                @Model.Seconds.ToString("D2") •
                                @Model.ReleaseDate.ToString("dd MMM yyyy")
                            </p>

                            <div class="fw-bold fs-6">
                                Artists:
                                @foreach (var artist in Model.Artists)
                                {
                                    <span class="badge bg-light text-dark border rounded-pill me-1 px-3">
                                        @artist
                                    </span>
                                }
                            </div>

                        </div>

                    </div>

                    <hr class="mb-4" />

                    <!-- Songs List -->
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">

                            <thead class="bg-light text-secondary">
                                <tr class="small text-uppercase">
                                    <th class="ps-3">#</th>
                                    <th>Title</th>
                                    <th>Length</th>
                                    <th>Genre</th>
                                    <th>Artists</th>
                                    @if (User.IsInRole("Artist") && Model.UserIds.Contains(currentUserId))
                                    {
                                        <th>Actions</th>
                                    }
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int index = 1;
                                }

                                @foreach (var song in Model.Songs)
                                {
                                    <tr class="border-top">

                                        <td class="ps-3 text-muted fw-semibold">
                                            @index
                                        </td>

                                        <td class="fw-semibold text-dark">
                                            <i class="bi bi-music-note text-secondary me-2"></i>
                                            @song.Title
                                        </td>

                                        <td class="text-muted">
                                            @song.Minutes.ToString("D2"):@song.Seconds.ToString("D2")
                                        </td>

                                        <td>
                                            <span class="badge bg-secondary bg-opacity-75 rounded-pill px-3">
                                                @song.Genre
                                            </span>
                                        </td>

                                        <td>
                                            @foreach (var artist in song.Artists)
                                            {
                                                <span class="badge bg-light text-dark border rounded-pill me-1 px-3">
                                                    @artist
                                                </span>
                                            }
                                        </td>

                                        @if (User.IsInRole("Artist") && Model.UserIds.Contains(currentUserId))
                                        {
                                            <td>
                                                <form asp-controller="Song" asp-action="MakeSongSingle" asp-route-songId="@song.Id" asp-route-albumId="@Model.Id">
                                                    <button class="btn btn-lg btn-warning rounded-5"><svg viewBox="0 0 640 640" width="30" height="30" class="me-2"><path fill="rgb(255, 255, 255)" d="M532 71C539.6 77.1 544 86.3 544 96L544 400C544 444.2 501 480 448 480C395 480 352 444.2 352 400C352 355.8 395 320 448 320C459.2 320 470 321.6 480 324.6L480 207.9L256 257.7L256 464C256 508.2 213 544 160 544C107 544 64 508.2 64 464C64 419.8 107 384 160 384C171.2 384 182 385.6 192 388.6L192 160C192 145 202.4 132 217.1 128.8L505.1 64.8C514.6 62.7 524.5 65 532.1 71.1z" /></svg>Single</button>
                                                </form>
                                            </td>
                                        }
                                    </tr>

                                    index++;
                                }

                            </tbody>

                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
