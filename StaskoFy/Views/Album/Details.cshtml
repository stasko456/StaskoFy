@model AlbumSongsIndexViewModel

@{
    var currentUserId = Guid.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier));
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
                    
            <div class="card shadow-lg border-0 rounded-4 card-album-details">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex flex-column flex-lg-row align-items-center align-items-lg-start gap-4 mb-5">

                        <div class="d-flex flex-column gap-4">
                            <div class="details-card-container position-relative">
                                <img src="@Model.ImageURL"
                                     alt="@Model.Title"
                                     class="rounded-4 shadow flex-shrink-0 song-image"
                                     style="width:300px; height:300px; object-fit:cover;">

                                <button class="btn play-btn-overlay"
                                        type="button"
                                        data-song-id="@Model.Id"
                                        onclick="loadSongsFromAlbumToQueue('@Model.Id')">
                                    <svg viewBox="0 0 640 640" height="70" width="70" style="background-color:transparent">
                                        <path fill="#ffc107" d="M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center text-center" style="min-height:300px;">

                            <h2 class="fw-bold">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" height="50" width="50"><!--!Font Awesome Free v7.2.0 by @@fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path fill="rgb(255, 255, 255)" d="M0 256a256 256 0 1 1 512 0 256 256 0 1 1 -512 0zm256 32a32 32 0 1 1 0-64 32 32 0 1 1 0 64zm-96-32a96 96 0 1 0 192 0 96 96 0 1 0 -192 0zm-56-16c0-32.4 16.3-66.6 42.8-93.2S207.6 104 240 104c13.3 0 24-10.7 24-24s-10.7-24-24-24c-47.9 0-93.7 23.5-127.1 56.9S56 192.1 56 240c0 13.3 10.7 24 24 24s24-10.7 24-24z" /></svg><span class="specific_heading">@Model.Title</span>
                            </h2>

                            <p class="text-muted fw-bold fs-6 mb-2">
                                @Model.SongsCount songs •
                                @Model.Hours.ToString("D2"):@Model.Minutes.ToString("D2"):@Model.Seconds.ToString("D2") •
                                @Model.ReleaseDate.ToString("dd MMM yyyy")
                            </p>

                            <div class="mb-3 fw-bold fs-6">
                                Artists:
                                @foreach (var artist in Model.Artists)
                                {
                                    <span class="badge" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3);">
                                        @artist
                                    </span>
                                }
                            </div>
                        </div>

                    </div>

                    <hr class="mb-4" />

                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-hover">

                            <thead class="bg-light text-secondary">
                                <tr class="small text-uppercase">
                                    <th class="ps-3">#</th>
                                    <th>Title</th>
                                    <th>Length</th>
                                    <th>Genre</th>
                                    <th>Artists</th>
                                    @if (User.IsInRole("Artist") && Model.UserIds.Contains(currentUserId))
                                    {
                                        <th>Actions</th>
                                    }
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int index = 1;
                                }

                                @foreach (var song in Model.Songs)
                                {
                                    <tr class="border-top">

                                        <td class="ps-3 text-muted fw-semibold">
                                            @index
                                        </td>

                                        <td class="fw-semibold text-dark">
                                            
                                            @song.Title
                                        </td>

                                        <td class="text-muted">
                                            @song.Minutes.ToString("D2"):@song.Seconds.ToString("D2")
                                        </td>

                                        <td>
                                            <span class="badge bg-secondary bg-opacity-75 rounded-pill px-3">
                                                @song.Genre
                                            </span>
                                        </td>

                                        <td>
                                            @foreach (var artist in song.Artists)
                                            {
                                                <span class="badge" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3);">
                                                    @artist
                                                </span>
                                            }
                                        </td>

                                        @if (User.IsInRole("Artist") && Model.UserIds.Contains(currentUserId))
                                        {
                                            <td>
                                                <div class="d-flex gap-2 align-items-center mt-1">
                                                    <a asp-controller="Song" asp-action="Edit" asp-route-id="@song.Id" class="btn btn-outline-warning btn-md d-inline-flex align-items-center">
                                                        <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                                            <path fill="currentColor" d="M535.6 85.7C513.7 63.8 478.3 63.8 456.4 85.7L432 110.1L529.9 208L554.3 183.6C576.2 161.7 576.2 126.3 554.3 104.4L535.6 85.7zM236.4 305.7C230.3 311.8 225.6 319.3 222.9 327.6L193.3 416.4C190.4 425 192.7 434.5 199.1 441C205.5 447.5 215 449.7 223.7 446.8L312.5 417.2C320.7 414.5 328.2 409.8 334.4 403.7L496 241.9L398.1 144L236.4 305.7zM160 128C107 128 64 171 64 224L64 480C64 533 107 576 160 576L416 576C469 576 512 533 512 480L512 384C512 366.3 497.7 352 480 352C462.3 352 448 366.3 448 384L448 480C448 497.7 433.7 512 416 512L160 512C142.3 512 128 497.7 128 480L128 224C128 206.3 142.3 192 160 192L256 192C273.7 192 288 177.7 288 160C288 142.3 273.7 128 256 128L160 128z" />
                                                        </svg>
                                                        Edit
                                                    </a>

                                                    <form asp-controller="Song" asp-action="Delete" method="post" asp-route-id="@song.Id">
                                                        <button class="btn btn-outline-danger btn-md d-inline-flex align-items-center" onclick="return confirm('Are you sure you want to delete this song?');">
                                                            <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                                                <path fill="currentColor" d="M232.7 69.9L224 96L128 96C110.3 96 96 110.3 96 128C96 145.7 110.3 160 128 160L512 160C529.7 160 544 145.7 544 128C544 110.3 529.7 96 512 96L416 96L407.3 69.9C402.9 56.8 390.7 48 376.9 48L263.1 48C249.3 48 237.1 56.8 232.7 69.9zM512 208L128 208L149.1 531.1C150.7 556.4 171.7 576 197 576L443 576C468.3 576 489.3 556.4 490.9 531.1L512 208z" />
                                                            </svg>
                                                            Delete
                                                        </button>
                                                    </form>

                                                    <form asp-controller="Song" asp-action="MakeSongSingle" asp-route-songId="@song.Id" asp-route-albumId="@Model.Id">
                                                        <button class="btn btn-outline-warning btn-md d-inline-flex align-items-center">
                                                            <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                                                <path fill="currentColor" d="M532 71C539.6 77.1 544 86.3 544 96L544 400C544 444.2 501 480 448 480C395 480 352 444.2 352 400C352 355.8 395 320 448 320C459.2 320 470 321.6 480 324.6L480 207.9L256 257.7L256 464C256 508.2 213 544 160 544C107 544 64 508.2 64 464C64 419.8 107 384 160 384C171.2 384 182 385.6 192 388.6L192 160C192 145 202.4 132 217.1 128.8L505.1 64.8C514.6 62.7 524.5 65 532.1 71.1z" />
                                                            </svg>
                                                            Single
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        }
                                    </tr>

                                    index++;
                                }

                            </tbody>

                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
