@model LikedSongsPaginationViewModel

@section _SearchBarPartial {
    <partial name="_SearchBarPartial" />
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <div class="card shadow-lg border-0 rounded-4 liked-songs-card">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex flex-column flex-lg-row align-items-center align-items-lg-start gap-4 mb-5">
                        <!-- Liked songs Image -->
                        <img src="/images/defaults/liked_songs.jpg"
                             alt="Liked songs"
                             class="rounded-4 shadow flex-shrink-0"
                             style="width:300px; height:300px; object-fit:cover;">
                        
                        <!-- Liked songs Info -->
                        <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center text-center" style="min-height:300px;">

                            <h2 class="fw-bold">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" height="50" width="50" class=""><!--!Font Awesome Free v7.2.0 by @@fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path fill="rgb(255, 255, 255)" d="M0 256a256 256 0 1 1 512 0 256 256 0 1 1 -512 0zm256 32a32 32 0 1 1 0-64 32 32 0 1 1 0 64zm-96-32a96 96 0 1 0 192 0 96 96 0 1 0 -192 0zm-56-16c0-32.4 16.3-66.6 42.8-93.2S207.6 104 240 104c13.3 0 24-10.7 24-24s-10.7-24-24-24c-47.9 0-93.7 23.5-127.1 56.9S56 192.1 56 240c0 13.3 10.7 24 24 24s24-10.7 24-24z" /></svg><span class="specific_heading">Liked Songs</span>
                            </h2>

                            <p class="text-muted fw-bold fs-6 mb-2">
                                @Model.LikedSongsCount songs •
                                @Model.LikedSongsHours.ToString("D2"):@Model.LikedSongsMinutes.ToString("D2"):@Model.LikedSongsSeconds.ToString("D2")
                            </p>
                        </div>
                    </div>

                    <hr class="mb-4" />

                    <!-- Songs List -->
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-hover">

                            <thead class="bg-light text-secondary">
                                <tr class="small text-uppercase">
                                    <th class="ps-3">#</th>
                                    <th>Song</th>
                                    <th>Album</th>
                                    <th>Length</th>
                                    <th>Artists</th>
                                    <th>Date Added</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int index = 1;
                                }

                                @foreach (var song in Model.LikedSongs)
                                {
                                    <tr class="border-top">

                                        <!-- Index -->
                                        <td class="ps-3 text-muted fw-semibold">
                                            @index
                                        </td>

                                        <!-- Song + Image -->
                                        <td class="fw-semibold text-dark">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@song.ImageUrl"
                                                     alt="@song.Title"
                                                     width="50"
                                                     height="50"
                                                     class="rounded shadow-sm" />

                                                <span>@song.Title</span>
                                            </div>
                                        </td>

                                        <!-- Album -->
                                        <td class="text-muted">
                                            @song.AlbumTitle
                                        </td>

                                        <!-- Length -->
                                        <td class="text-muted">
                                            @song.Minutes.ToString("D2"):@song.Seconds.ToString("D2")
                                        </td>

                                        <!-- Artists -->
                                        <td>
                                            @foreach (var artist in song.Artists)
                                            {
                                                <span class="badge" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3);">
                                                    @artist
                                                </span>
                                            }
                                        </td>

                                        <!-- Date Added -->
                                        <td class="text-muted">
                                            @song.DateAdded.ToString("dd MMM yyyy")
                                        </td>

                                        <td>
                                            <form method="post" asp-controller="LikedSongs" asp-action="RemoveLikedSong" asp-route-songId="@song.SongId">
                                                <button class="btn btn-outline-danger btn-md d-inline-flex align-items-center">
                                                    <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                                        <path fill="currentColor" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM232 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296z" />
                                                    </svg>
                                                    Remove
                                                </button>
                                            </form>
                                        </td>
                                    </tr>

                                    index++;
                                }

                            </tbody>

                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    <nav>
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="LikedSongs" asp-action="LikedSongsIndexForCurrentLoggedUser" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-pageSize="3">Previous</a>
                </li>
            }

            @if (Model.CurrentPage > 2)
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="LikedSongs" asp-action="LikedSongsIndexForCurrentLoggedUser" asp-route-pageNumber="1" asp-route-pageSize="3">1</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            @for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
            {
                if (i > 0 && i <= Model.TotalPages)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-controller="LikedSongs" asp-action="LikedSongsIndexForCurrentLoggedUser" asp-route-pageNumber="@i" asp-route-pageSize="3">@i</a>
                    </li>
                }
            }

            @if (Model.CurrentPage < Model.TotalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-controller="LikedSongs" asp-action="LikedSongsIndexForCurrentLoggedUser" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="3">@Model.TotalPages</a>
                </li>
            }

            <!-- Next Page Link -->
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="LikedSongs" asp-action="LikedSongsIndexForCurrentLoggedUser" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-pageSize="3">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>