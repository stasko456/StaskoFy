@model UsersPaginationViewModel

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold mb-3">
        Discover <span class="specific_heading">Users</span>
    </h1>

    <p class="lead text-dark mb-1">
        Explore all users on the platform.
    </p>
</div>

<div class="row justify-content-center w-100 mx-0">
    <div class="col-12 col-md-8 col-lg-6 mb-4 mx-auto">
        <form asp-controller="User" asp-action="Index" method="get">
            <div class="d-flex align-items-center gap-4 mb-4">
                <input class="form-control form-control-lg"
                       type="search"
                       placeholder="Search users..."
                       name="username"
                       value="@Context.Request.Query["username"]" />
                <button type="submit" class="btn btn-search btn-lg d-inline-flex align-items-center px-4">
                    <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                        <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                    </svg>
                    Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="container">
    <div class="row g-4 justify-content-center">
        @if (Model.Users.Any())
        {
            @foreach (var user in Model.Users)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm h-100 text-center artist-card"
                         style="background-color: #1a1a1a; border-radius: 15px; transition: all 0.3s ease; padding-bottom: 20px;">

                        <a asp-controller="User" asp-action="UserDetails" asp-route-id="@user.Id" class="text-decoration-none">
                            <div class="position-relative d-inline-block mt-4">
                                <img src="@user.ProfilePicture"
                                     class="rounded-circle mx-auto"
                                     alt="@user.Username"
                                     style="width:150px; height:150px; object-fit:cover; border: 3px solid rgba(255, 193, 7, 0.2); box-shadow: 0 8px 20px rgba(0,0,0,0.4);">
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title mt-2 fw-bold text-white" style="letter-spacing: 0.5px;">
                                    @user.Username
                                </h5>
                            </div>
                        </a>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <h4 class="text-white fw-light">@ViewData["NoResult"]</h4>
                <p class="text-secondary">Try searching for a different user.</p>

                <div class="mt-4">
                    <a href="@Url.Action("Index", "User")" class="btn btn-outline-warning px-4 me-2">Clear Search</a>
                </div>
            </div>
        }
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    <nav>
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-pageSize="3">Previous</a>
                </li>
            }

            @if (Model.CurrentPage > 2)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="1" asp-route-pageSize="3">1</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            @for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
            {
                if (i > 0 && i <= Model.TotalPages)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-pageSize="3">@i</a>
                    </li>
                }
            }

            @if (Model.CurrentPage < Model.TotalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="3">@Model.TotalPages</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-pageSize="3">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>