@model ProfileIndexViewModel

<div class="container py-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-5">
            <div class="form-studio-card">


                <div class="form-studio-header">
                    <div class="form-studio-header__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4Zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10Z"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="form-studio-header__title">My <span>Profile</span></h2>
                        <p class="form-studio-header__subtitle">Your account information</p>
                    </div>
                </div>

                <div class="form-studio-body">


                    <div class="form-studio-section text-center">
                        <img src="@Model.ProfilePicture"
                             class="rounded-circle mb-4 user-profile-img"
                             width="130"
                             height="130">

                        <h3 class="fw-bold text-white mb-1">@Model.Username</h3>
                        <p class="mb-0 text-muted" style="font-size:0.875rem;">Member of the platform</p>
                    </div>


                    <div class="form-studio-actions">
                        <a asp-controller="Home" asp-action="Index" class="form-studio-actions__cancel">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                            </svg>
                            Back
                        </a>

                        @if (!User.IsInRole("Admin"))
                        {
                            <a asp-controller="User" asp-action="Manage" class="form-studio-actions__submit form-studio-actions__submit--edit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                                </svg>
                                Edit Profile
                            </a>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>