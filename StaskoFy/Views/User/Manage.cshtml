@model EditProfileViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm user-edit-profile-card">

                <div class="text-center mb-3 mt-3">
                    <h4 class="display-4 fw-bold">
                        Edit <span class="text-warning">Profile</span>
                    </h4>
                </div>

                <div class="card-body">

                    <form asp-action="Manage" method="post" enctype="multipart/form-data">

                        <div class="text-center mb-4">
                            <img src="@Model.CurrentProfilePicture"
                                 class="rounded-circle"
                                 width="170"
                                 height="170"
                                 style="object-fit:cover;" />
                        </div>

                        <div class="col-md-10 mx-auto">

                            <div class="mb-3">
                                <label asp-for="Username" class="form-label fw-semibold fs-5"></label>
                                <input asp-for="Username" class="form-control" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ImageFile" class="form-label fw-semibold fs-5">Change Profile Picture</label>
                                <input type="file" asp-for="ImageFile" class="form-control" accept="image/*" />
                            </div>
                            
                            <div class="d-flex justify-content-between">
                                <a asp-action="Details" class="btn btn-outline-warning">Cancel</a>

                                <button type="submit" class="btn btn-warning btn-wan">Save Changes</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}