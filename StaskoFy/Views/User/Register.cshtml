@model RegisterViewModel

<div class="container py-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-9">
            <div class="card shadow-lg border-0 rounded-4 login-register-card">
                <div class="card-body p-4 p-md-5">
                    <h2 class="text-center mb-5 fw-bold">
                        <svg viewBox="0 0 640 640" width="50" height="50" class="me-1">
                            <path fill="rgb(255, 255, 255)" d="M285.7 304c98.5 0 178.3 79.8 178.3 178.3 0 16.4-13.3 29.7-29.7 29.7L77.7 512C61.3 512 48 498.7 48 482.3 48 383.8 127.8 304 226.3 304l59.4 0zM528 80c13.3 0 24 10.7 24 24l0 48 48 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-48 0 0 48c0 13.3-10.7 24-24 24s-24-10.7-24-24l0-48-48 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l48 0 0-48c0-13.3 10.7-24 24-24zM256 248a120 120 0 1 1 0-240 120 120 0 1 1 0 240z" />
                        </svg><span class="specific_heading">Register</span>
                    </h2>

                    <form id="registerForm" method="post" asp-action="Register">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4">
                            <fieldset class="col-12 col-lg-6">
                                <div class="mb-3">
                                    <label asp-for="Username" class="form-label fw-semibold fs-5">Username</label>
                                    <input asp-for="Username" class="form-control" placeholder="Enter username" />
                                    <span asp-validation-for="Username" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="EmailAddress" class="form-label fw-semibold fs-5">Email</label>
                                    <input asp-for="EmailAddress" class="form-control" placeholder="Enter email" />
                                    <span asp-validation-for="EmailAddress" class="text-danger small"></span>
                                </div>
                            </fieldset>

                            <fieldset class="col-12 col-lg-6">
                                <div class="mb-3">
                                    <label asp-for="Password" class="form-label fw-semibold fs-5">Password</label>
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label fw-semibold fs-5">Confirm Password</label>
                                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm password" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Role" class="form-label fw-semibold fs-5">Role</label>
                                    <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select">
                                        <option value="">-- Select role --</option>
                                    </select>
                                    <span asp-validation-for="Role" class="text-danger small"></span>
                                </div>
                            </fieldset>
                        </div>

                        <hr class="my-4 opacity-25" />

                        <div class="text-center text-muted">
                            <p class="mb-3">Already have an account? <a asp-action="Login" class="text-warning text-decoration-none fw-bold">Log in now</a></p>
                            <button id="registerSubmit" type="submit" class="btn btn-outline-warning btn-lg w-50 rounded-4 shadow-sm fs-5">
                                Create Account
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>