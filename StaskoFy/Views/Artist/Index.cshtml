@model List<ArtistIndexWithProjects>

@{
    ViewData["Title"] = "Artists";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">
            Discover <span class="text-warning">Artists</span>
        </h1>
        <p class="text-muted">Explore all artists on the platform</p>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-md-6">
            <input type="text" class="form-control form-control-lg shadow-sm"
                   placeholder="Search artists...">
        </div>
    </div>

    <div class="row g-4">

        @if (Model.Any())
        {
            @foreach (var artist in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm h-100 text-center artist-card">

                        <img src="@(string.IsNullOrEmpty(artist.ProfilePicture) 
                                    ? "/images/default-artist.png" 
                                    : artist.ProfilePicture)"
                             class="card-img-top rounded-circle mx-auto mt-4"
                             alt="@artist.Username"
                             style="width:150px; height:150px; object-fit:cover;">

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mt-3 fw-bold">
                                @artist.Username
                            </h5>

                            @*<p class="text-muted mb-3">
                                @artist.FollowersCount followers
                    </p>*@

                            <div class="mt-auto">
                                <a asp-controller="Artist" asp-action="Details" asp-route-id="@artist.Id" class="btn btn-warning btn-sm px-4">
                                    <svg viewBox="0 0 640 640" width="30" height="30" class="me-2">
                                        <path fill="rgb(0, 0, 0)" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM288 224C288 206.3 302.3 192 320 192C337.7 192 352 206.3 352 224C352 241.7 337.7 256 320 256C302.3 256 288 241.7 288 224zM280 288L328 288C341.3 288 352 298.7 352 312L352 400L360 400C373.3 400 384 410.7 384 424C384 437.3 373.3 448 360 448L280 448C266.7 448 256 437.3 256 424C256 410.7 266.7 400 280 400L304 400L304 336L280 336C266.7 336 256 325.3 256 312C256 298.7 266.7 288 280 288z" />
                                    </svg>View Profile
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p class="text-muted fs-5">
                    No artists found.
                </p>
            </div>
        }

    </div>
</div>