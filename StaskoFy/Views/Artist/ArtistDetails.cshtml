@model ArtistIndexWithProjects

<div class="container mt-4">

    <div class="text-center text-light mb-5">
        <img src="@Model.ProfilePicture"
             class="rounded-circle shadow mb-3"
             width="150"
             height="150"
             style="object-fit:cover;" />

        <h1 class="display-4 fw-bold specific_heading">
            @Model.Username
        </h1>
        <p class="text-muted fs-5">Artist</p>
    </div>

    <ul class="nav nav-pills justify-content-start mb-4" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="pills-singles-tab" data-bs-toggle="pill" data-bs-target="#pills-singles" type="button" role="tab">Singles & Features</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pills-albums-tab" data-bs-toggle="pill" data-bs-target="#pills-albums" type="button" role="tab">Albums</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pills-playlists-tab" data-bs-toggle="pill" data-bs-target="#pills-playlists" type="button" role="tab">Playlists</button>
        </li>
    </ul>

    <hr />

    <div class="tab-content" id="pills-tabContent">
        <div class="tab-pane fade show active" id="pills-singles" role="tabpanel">
            <div class="text-light text-center">
                <h3 class="fw-bold mb-3">
                    @Model.Username's <span class="specific_heading">Singles</span>
                </h3>
            </div>
            @if (!Model.Singles.Any())
            {
                <div class="alert alert-light border rounded-4 text-center fw-semibold shadow-sm fs-5 mb-5 mt-5">
                    @ViewData["NoSingles"]
                </div>
            }
            else
            {
                <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-6 mx-auto justify-content-center mt-4" style="max-width: 1200px;">
                    @foreach (var song in Model.Singles)
                    {
                        <div class="col" id="song-@song.Id">
                            <div class="card h-100 border-0 song-card-container"
                                 style="border-radius: 12px; background-color: #1a1a1a; transition: transform 0.3s ease, box-shadow 0.3s ease; overflow: visible;">

                                <div style="position: relative; width: 100%; padding-bottom: 100%; background-color: #2a2a2a; border-radius: 12px 12px 0 0; overflow: hidden;">
                                    <a asp-controller="Song" asp-action="Details" asp-route-id="@song.Id">
                                        <img src="@song.ImageURL"
                                             alt="@song.Title"
                                             style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;">
                                    </a>
                                </div>

                                <div class="card-body p-3 d-flex flex-column">
                                    <h6 class="card-title mb-3 text-truncate text-white" title="@song.Title" style="font-weight: 700; font-size: 0.95rem;">
                                        @song.Title
                                    </h6>

                                    <div class="mt-auto">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-controller="Song" asp-action="Delete" method="post" asp-route-id="@song.Id">
                                                <button class="btn btn-outline-danger btn-sm w-100 py-2 d-flex align-items-center justify-content-center"
                                                        style="border-radius: 8px; font-weight: 600;"
                                                        onclick="return confirm('Are you sure you want to delete this song?');">
                                                    <svg viewBox="0 0 448 512" width="14" height="14" class="me-2">
                                                        <path fill="currentColor" d="M136.7 5.9L128 32 32 32C14.3 32 0 46.3 0 64S14.3 96 32 96l384 0c17.7 0 32-14.3 32-32s-14.3-32-32-32l-96 0-8.7-26.1C306.9-7.2 294.7-16 280.9-16L167.1-16c-13.8 0-26 8.8-30.4 21.9zM416 144L32 144 53.1 467.1C54.7 492.4 75.7 512 101 512L347 512c25.3 0 46.3-19.6 47.9-44.9L416 144z" />
                                                    </svg>Delete
                                                </button>
                                            </form>
                                        }
                                        else if (User.IsInRole("Artist") || User.IsInRole("User"))
                                        {
                                            <div class="dropup w-100">
                                                <button class="btn btn-sm w-100 d-flex align-items-center justify-content-center py-2"
                                                        type="button"
                                                        data-bs-toggle="dropdown"
                                                        aria-expanded="false"
                                                        style="background-color: rgba(255,255,255,0.05); color: #adb5bd; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; font-weight: 600;">
                                                    <svg viewBox="0 0 128 512" width="16" height="16" class="me-2">
                                                        <path fill="currentColor" d="M64 352c-35.3 0-64 28.7-64 64s28.7 64 64 64 64-28.7 64-64-28.7-64-64-352zm0-160c-35.3 0-64 28.7-64 64s28.7 64 64 64 64-28.7 64-64-28.7-64-64-160zm0-160C28.7 32 0 60.7 0 96s28.7 64 64 64 64-28.7 64-64-28.7-64-64-64z" />
                                                    </svg>Options
                                                </button>

                                                <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary" style="border-radius: 10px; padding: 8px 0;">
                                                    <li class="dropdown-submenu position-relative">
                                                        <a class="dropdown-item d-flex align-items-center py-2" style="cursor: pointer;">
                                                            <svg viewBox="0 0 640 640" width="18" height="18" class="me-2 text-white">
                                                                <path fill="currentColor" d="M64 80c-8.8 0-16 7.2-16 16l0 320c0 8.8 7.2 16 16 16l320 0c8.8 0 16-7.2 16-16l0-320c0-8.8-7.2-16-16-16L64 80zM0 96C0 60.7 28.7 32 64 32l320 0c35.3 0 64 28.7 64 64l0 320c0 35.3-28.7 64-64 64L64 480c-35.3 0-64-28.7-64-64L0 96zM200 344l0-64-64 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l64 0 0-64c0-13.3 10.7-24 24-24s24 10.7 24 24l0 64 64 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-64 0 0 64c0 13.3-10.7 24-24 24s-24-10.7-24-24z" />
                                                            </svg>
                                                            <span>Add to Playlist</span>
                                                        </a>
                                                        <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary" style="border-radius: 10px;">
                                                            @if (Model.LoggedUserPlaylists != null && Model.LoggedUserPlaylists.Any())
                                                            {
                                                                foreach (var playlist in Model.LoggedUserPlaylists)
                                                                {
                                                                    <li>
                                                                        <form method="post" asp-controller="Playlist" asp-action="AddSongToPlaylist">
                                                                            <input type="hidden" name="playlistId" value="@playlist.Id" />
                                                                            <input type="hidden" name="songId" value="@song.Id" />
                                                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#song-@song.Id" />
                                                                            <button type="submit" class="dropdown-item py-2">@playlist.Title</button>
                                                                        </form>
                                                                    </li>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <li><span class="dropdown-item-text text-muted small">No playlists found</span></li>
                                                            }
                                                        </ul>
                                                    </li>

                                                    <li><hr class="dropdown-divider border-secondary" /></li>

                                                    <li>
                                                        <form method="post" asp-controller="LikedSongs" asp-action="AddLikedSong" asp-route-songId="@song.Id">
                                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString#song-@song.Id" />
                                                            <button type="submit" class="dropdown-item py-2 fw-bold" style="color: #ffc107 !important;">
                                                                Add to Liked Songs
                                                            </button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="tab-pane fade" id="pills-albums" role="tabpanel">
            <div class="text-light text-center">
                <h3 class="fw-bold mb-3">
                    @Model.Username's <span class="specific_heading">Albums</span>
                </h3>
            </div>
            @if (!Model.Albums.Any())
            {
                <div class="alert alert-light border rounded-4 text-center fw-semibold shadow-sm fs-5 mb-5 mt-5">
                    @ViewData["NoAlbums"]
                </div>
            }
            else
            {
                <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 justify-content-center mt-4">
                    @foreach (var album in Model.Albums)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm song-card-container border-0"
                                 style="border-radius: 12px; background-color: #1a1a1a; transition: transform 0.3s ease; overflow: hidden;">

                                <div class="position-relative overflow-hidden" style="aspect-ratio: 1 / 1; background-color: #2a2a2a;">
                                    <a asp-action="Details" asp-route-id="@album.Id">
                                        <img src="@album.ImageURL"
                                             alt="@album.Title"
                                             class="w-100 h-100"
                                             style="object-fit: cover;">
                                    </a>
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <h5 class="card-title text-white mb-2 text-truncate" style="font-weight: 700; font-size: 1.1rem;" title="@album.Title">
                                        @album.Title
                                    </h5>

                                    <div class="mb-3">
                                        @foreach (var artist in album.Artists)
                                        {
                                            <span class="badge" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3);">
                                                @artist
                                            </span>
                                        }
                                    </div>

                                    <div class="album-info-list" style="font-size: 0.85rem; color: #adb5bd;">

                                        <div class="d-flex align-items-center mb-2">
                                            <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm0 448c-110.5 0-200-89.5-200-200S145.5 56 256 56s200 89.5 200 200-89.5 200-200 200zm61.8-104.4l-84.9-61.7c-3.1-2.3-4.9-5.9-4.9-9.7V116c0-6.6 5.4-12 12-12h32c6.6 0 12 5.4 12 12v141.7l66.8 48.6c5.4 3.9 6.5 11.4 2.6 16.8L333.8 343c-3.9 5.3-11.4 6.4-16.8 2.6z" />
                                            </svg>
                                            <span><strong>Length:</strong> @album.Hours.ToString("D2"):@album.Minutes.ToString("D2"):@album.Seconds.ToString("D2")</span>
                                        </div>

                                        <div class="d-flex align-items-center mb-2">
                                            <svg viewBox="0 0 448 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M148 288h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v40c0-6.6-5.4-12-12-12zm108-52v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 96v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm192 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96-260v352c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V112c0-26.5 21.5-48 48-48h48V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h128V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h48c26.5 0 48 21.5 48 48zM400 464V192H48v272h352z" />
                                            </svg>
                                            <span><strong>Released:</strong> @album.ReleaseDate.ToString("dd MMM yyyy")</span>
                                        </div>

                                        <div class="d-flex align-items-center mb-3">
                                            <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M470.38 1.51L150.41 96A32 32 0 0 0 128 126.51v261.41A139 139 0 0 0 96 384c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V214.32l256-75v184.61a138.4 138.4 0 0 0-32-4c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V32a32 32 0 0 0-41.62-30.49z" />
                                            </svg>
                                            <span><strong>Songs:</strong> @album.SongsCount</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="tab-pane fade" id="pills-playlists" role="tabpanel">
            <div class="text-light text-center">
                <h3 class="fw-bold mb-3">
                    @Model.Username's <span class="specific_heading">Playlists</span>
                </h3>
            </div>
            @if (!Model.Playlists.Any())
            {
                <div class="alert alert-light border rounded-4 text-center fw-semibold shadow-sm fs-5 mb-5 mt-5">
                    @ViewData["NoPlaylists"]
                </div>
            }
            else
            {
                <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 justify-content-center mt-4">
                    @foreach (var playlist in Model.Playlists)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 playlist-hover-card"
                                 style="border-radius: 12px; background-color: #1a1a1a; transition: transform 0.3s ease; overflow: hidden;">

                                <div class="position-relative overflow-hidden" style="aspect-ratio: 1 / 1; background-color: #2a2a2a;">
                                    <a asp-controller="Playlist" asp-action="Details" asp-route-id="@playlist.Id">
                                        <img src="@playlist.ImageURL"
                                             alt="@playlist.Title"
                                             class="w-100 h-100"
                                             style="object-fit: cover;">
                                    </a>
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <h5 class="card-title text-white mb-3 text-truncate" style="font-weight: 700; font-size: 1.1rem;" title="@playlist.Title">
                                        @playlist.Title
                                    </h5>

                                    <div style="font-size: 0.85rem; color: #adb5bd;">
                                        <div class="d-flex align-items-center mb-2">
                                            <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm0 448c-110.5 0-200-89.5-200-200S145.5 56 256 56s200 89.5 200 200-89.5 200-200 200zm61.8-104.4l-84.9-61.7c-3.1-2.3-4.9-5.9-4.9-9.7V116c0-6.6 5.4-12 12-12h32c6.6 0 12 5.4 12 12v141.7l66.8 48.6c5.4 3.9 6.5 11.4 2.6 16.8L333.8 343c-3.9 5.3-11.4 6.4-16.8 2.6z" />
                                            </svg>
                                            <span><strong>Length:</strong> @playlist.Hours:@playlist.Minutes.ToString("D2"):@playlist.Seconds.ToString("D2")</span>
                                        </div>

                                        <div class="d-flex align-items-center mb-2">
                                            <svg viewBox="0 0 448 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M148 288h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v40c0-6.6-5.4-12-12-12zm108-52v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 96v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm-96 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm192 0v40c0 6.6-5.4 12-12 12h-40c-6.6 0-12-5.4-12-12v-40c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12zm96-260v352c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V112c0-26.5 21.5-48 48-48h48V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h128V12c0-6.6 5.4-12 12-12h40c6.6 0 12 5.4 12 12v52h48c26.5 0 48 21.5 48 48zM400 464V192H48v272h352z" />
                                            </svg>
                                            <span><strong>Created:</strong> @playlist.DateCreated.ToString("dd MMM yyyy")</span>
                                        </div>

                                        <div class="d-flex align-items-center mb-3">
                                            <svg viewBox="0 0 512 512" width="16" height="16" class="me-2" style="color: #ffc107;">
                                                <path fill="currentColor" d="M470.38 1.51L150.41 96A32 32 0 0 0 128 126.51v261.41A139 139 0 0 0 96 384c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V214.32l256-75v184.61a138.4 138.4 0 0 0-32-4c-53 0-96 28.65-96 64s43 64 96 64 96-28.65 96-64V32a32 32 0 0 0-41.62-30.49z" />
                                            </svg>
                                            <span><strong>Songs:</strong> @playlist.SongCount</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>