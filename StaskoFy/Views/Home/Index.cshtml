<div class="text-center mb-5">
    <h1 class="display-3 fw-bolder mb-3">
        Welcome to <span class="specific_heading">StaskoFy</span>
    </h1>

    <p class="lead text-dark mx-auto" style="max-width: 600px;">
        Your ultimate music streaming platform. Stream your favorite tracks, support emerging artists, and build the perfect playlists.
    </p>
</div>

<div class="container ">
    <div class="d-flex justify-content-center align-items-center mb-5">
        <div class="card shadow-lg border-0 rounded-4 login-register-card" style="max-width: 450px; width: 100%;">
            <div class="card-body p-5 text-center">
                <h4 class="card-title mb-3 fw-bold">Ready to listen?</h4>
                <p class="text-muted mb-4 small fs-6">Create an account to start building your library, or log in to pick up right where you left off.</p>

                <div class="d-grid gap-3">
                    <a asp-controller="User" asp-action="Register" class="btn btn-outline-warning btn-lg fw-bold rounded-pill shadow-sm">
                        Create an Account
                    </a>

                    <a asp-controller="User" asp-action="Login" class="btn btn-outline-warning btn-lg fw-bold rounded-pill">
                        Log In
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>