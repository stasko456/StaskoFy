@model PlaylistSongsPaginationViewModel

@{
    var currentUserId = Guid.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier));
}

<div class="container py-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <div class="mb-3">
                <a asp-controller="Home" asp-action="Index" class="specific_heading fs-5 text-decoration-none fw-bold d-inline-flex align-items-center">
                    <svg viewBox="0 0 320 512" width="16" height="16" fill="currentColor" class="me-2">
                        <path d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l192 192c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L77.3 256 246.6 86.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-192 192z" />
                    </svg>
                    Back
                </a>
            </div>

            <div class="card shadow-lg border-0 rounded-4 playlist-hover-card">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex flex-column flex-lg-row align-items-center align-items-lg-start gap-4 mb-5">

                        <div class="d-flex flex-column gap-4">
                            <div class="details-card-container position-relative">
                                <img src="@Model.PlaylistInfo.ImageURL"
                                     alt="@Model.PlaylistInfo.Title"
                                     class="rounded-4 shadow flex-shrink-0 song-image"
                                     style="width:300px; height:300px; object-fit:cover;">

                                <button class="btn play-btn-overlay"
                                        type="button"
                                        data-song-id="@Model.PlaylistInfo.Id"
                                        onclick="loadSongsFromPlaylistToQueue('@Model.PlaylistInfo.Id')">
                                    <svg viewBox="0 0 640 640" height="70" width="70" style="background-color:transparent">
                                        <path fill="#ffc107" d="M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center text-center w-100" style="min-height:300px;">

                            <h2 class="fw-bold d-flex align-items-center justify-content-center gap-2">
                                <svg viewBox="0 0 640 640" height="50" width="50"><path fill="rgb(255, 255, 255)" d="M0 256a256 256 0 1 1 512 0 256 256 0 1 1 -512 0zm256 32a32 32 0 1 1 0-64 32 32 0 1 1 0 64zm-96-32a96 96 0 1 0 192 0 96 96 0 1 0 -192 0zm-56-16c0-32.4 16.3-66.6 42.8-93.2S207.6 104 240 104c13.3 0 24-10.7 24-24s-10.7-24-24-24c-47.9 0-93.7 23.5-127.1 56.9S56 192.1 56 240c0 13.3 10.7 24 24 24s24-10.7 24-24z" /></svg>
                                <span class="specific_heading">@Model.PlaylistInfo.Title</span>
                            </h2>

                            <p class="text-muted fw-bold fs-6 mb-3">
                                @Model.SongsCount songs •
                                @Model.PlaylistLength.Hours.ToString("D2"):@Model.PlaylistLength.Minutes.ToString("D2"):@Model.PlaylistLength.Seconds.ToString("D2") •
                                @Model.PlaylistInfo.DateCreated.ToString("dd MMM yyyy")
                            </p>

                            <div id="search-bar-container" class="compact-search-group w-100 mt-5" style="max-width: 350px;">
                                <form method="get" class="mb-0" asp-controller="Playlist" asp-action="Details">
                                    <div class="d-flex gap-2">
                                        <input class="form-control custom-search-input"
                                               type="search"
                                               placeholder="Search..."
                                               name="name"
                                               value="@Context.Request.Query["name"]" />

                                        <button type="submit" class="btn btn-search custom-search-btn shadow-sm">
                                            <svg viewBox="0 0 640 640" style="width:16px; height:16px; margin-right: 5px;">
                                                <path fill="currentColor" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
                                            </svg>
                                            Search
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <hr class="mb-4" />

                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-hover">

                            <thead class="bg-light text-secondary">
                                <tr class="small text-uppercase">
                                    <th class="ps-3">#</th>
                                    <th>Song</th>
                                    <th>Album</th>
                                    <th>Length</th>
                                    <th>Artists</th>
                                    <th>Date Added</th>
                                    @if (!User.IsInRole("Admin") && Model.PlaylistInfo.UserId == currentUserId)
                                    {
                                        <th>Actions</th>
                                    }
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int index = 1;
                                }

                                @if (!Model.Songs.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center">
                                            <div class="text-center py-5">
                                                <h4 class="text-white fw-light">@ViewData["NoPlaylistSongs"]</h4>
                                                <p class="text-secondary">Try searching for a different track.</p>

                                                <div class="mt-4">
                                                    <a href="@Url.Action("Details", "Playlist")" class="btn btn-outline-warning px-4 me-2">Clear Search</a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var song in Model.Songs)
                                    {
                                        <tr class="border-top">

                                            <td class="ps-3 text-muted fw-semibold">
                                                @index
                                            </td>

                                            <td class="fw-semibold text-dark song-row">
                                                <div class="d-flex align-items-center gap-3">

                                                    <div class="position-relative d-inline-block hover-play-container" style="width: 50px; height: 50px;">
                                                        <img src="@song.ImageUrl"
                                                             alt="@song.Title"
                                                             class="rounded shadow-sm song-image"
                                                             style="width: 100%; height: 100%; object-fit: cover;" />

                                                        <button class="btn p-0 play-btn-custom position-absolute top-50 start-50 translate-middle play-overlay-btn"
                                                                type="button"
                                                                data-song-id="@song.Id"
                                                                onclick="loadSong('@song.Id')">
                                                            <svg viewBox="0 0 640 640" height="30" width="30" style="background-color:transparent">
                                                                <path fill="#ffc107" d="M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z" />
                                                            </svg>
                                                        </button>
                                                    </div>

                                                    <span>@song.Title</span>
                                                </div>
                                            </td>

                                            <td class="text-muted">
                                                @song.AlbumTitle
                                            </td>

                                            <td class="text-muted">
                                                @song.Minutes.ToString("D2"):@song.Seconds.ToString("D2")
                                            </td>

                                            <td>
                                                @foreach (var artist in song.Artists)
                                                {
                                                    <span class="badge" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3);">
                                                        @artist
                                                    </span>
                                                }
                                            </td>

                                            <td class="text-muted">
                                                @song.DateAdded.ToString("dd MMM yyyy")
                                            </td>

                                            @if (!User.IsInRole("Admin") && Model.PlaylistInfo.UserId == currentUserId)
                                            {
                                                <td>
                                                    <form method="post" asp-controller="Playlist" asp-action="RemoveSongFromPlaylist" asp-route-songId="@song.Id" asp-route-playlistId="@Model.PlaylistInfo.Id">
                                                        <button class="btn btn-outline-danger btn-md d-inline-flex align-items-center">
                                                            <svg viewBox="0 0 640 640" width="25" height="25" class="me-2">
                                                                <path fill="currentColor" d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM232 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296z" />
                                                            </svg>
                                                            Remove
                                                        </button>
                                                    </form>
                                                </td>
                                            }
                                        </tr>

                                        index++;
                                    }
                                }

                            </tbody>

                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    <nav>
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="Playlist" asp-action="Details" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-pageSize="3">Previous</a>
                </li>
            }

            @if (Model.CurrentPage > 2)
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="Playlist" asp-action="Details" asp-route-pageNumber="1" asp-route-pageSize="3">1</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            @for (int i = Model.CurrentPage - 1; i <= Model.CurrentPage + 1; i++)
            {
                if (i > 0 && i <= Model.TotalPages)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-controller="Playlist" asp-action="Details" asp-route-pageNumber="@i" asp-route-pageSize="3">@i</a>
                    </li>
                }
            }

            @if (Model.CurrentPage < Model.TotalPages - 1)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-controller="Playlist" asp-action="Details" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="3">@Model.TotalPages</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="Playlist" asp-action="Details" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-pageSize="3">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>