@model PlaylistSongsIndexViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex flex-column flex-lg-row align-items-center align-items-lg-start gap-4 mb-5">

                        <!-- Album Image -->
                        <img src="@Model.ImageURL"
                             alt="@Model.Title"
                             class="rounded-4 shadow flex-shrink-0"
                             style="width:300px; height:300px; object-fit:cover;">

                        <!-- Album Info -->
                        <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center text-center" style="min-height:300px;">

                            <h2 class="fw-bold">
                                <i class="bi bi-disc"></i>
                                <span class="text-warning">@Model.Title</span>
                            </h2>

                            <p class="text-muted fw-bold fs-6 mb-2">
                                @Model.SongCount songs •
                                @Model.Hours.ToString("D2"):
                                @Model.Minutes.ToString("D2"):
                                @Model.Seconds.ToString("D2") •
                                @Model.DateCreated.ToString("dd MMM yyyy")
                            </p>

                        </div>

                    </div>

                    @* <div class="mb-4 text-center">
                        <img src="@Model.ImageURL"
                             alt="@Model.Title"
                             class="img-fluid rounded-4 shadow mx-auto d-block"
                             style="max-width: 380px;">
                    </div>

                    <!-- Header -->
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">
                            <i class="bi bi-heart-fill text-danger"></i>
                            <span class="text-warning">@Model.Title</span>
                        </h2>
                        <p class="text-muted mb-0">
                            @Model.Songs.Count() Songs in this playlist
                        </p>
                    </div> *@

                    <hr class="mb-4" />

                    <!-- Songs List -->
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">

                            <thead class="bg-light text-secondary">
                                <tr class="small text-uppercase">
                                    <th class="ps-3">#</th>
                                    <th>Song</th>
                                    <th>Album</th>
                                    <th>Length</th>
                                    <th>Artists</th>
                                    <th>Date Added</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int index = 1;
                                }

                                @foreach (var song in Model.Songs)
                                {
                                    <tr class="border-top">

                                        <!-- Index -->
                                        <td class="ps-3 text-muted fw-semibold">
                                            @index
                                        </td>

                                        <!-- Song + Image -->
                                        <td class="fw-semibold text-dark">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@song.ImageUrl"
                                                     alt="@song.Title"
                                                     width="50"
                                                     height="50"
                                                     class="rounded shadow-sm" />

                                                <span>@song.Title</span>
                                            </div>
                                        </td>

                                        <!-- Album -->
                                        <td class="text-muted">
                                            @song.AlbumTitle
                                        </td>

                                        <!-- Length -->
                                        <td class="text-muted">
                                            @song.Minutes.ToString("D2"):@song.Seconds.ToString("D2")
                                        </td>

                                        <!-- Artists -->
                                        <td>
                                            @foreach (var artist in song.Artists)
                                            {
                                                <span class="badge bg-light text-dark border rounded-pill me-1 px-3">
                                                    @artist
                                                </span>
                                            }
                                        </td>

                                        <!-- Date Added -->
                                        <td class="text-muted">
                                            @song.DateAdded.ToString("dd MMM yyyy")
                                        </td>

                                        <td>
                                            <form method="post" asp-controller="Playlist" asp-action="RemoveSongFromPlaylist" asp-route-songId="@song.Id" asp-route-playlistId="@Model.Id">
                                                <button class="btn btn-danger btn-sm mt-2 px-4 py-2 rounded-pill shadow-sm d-flex align-items-center">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="me-2" width="30" height="30"><!--!Font Awesome Free v7.2.0 by @@fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M320 576C461.4 576 576 461.4 576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 461.4 178.6 576 320 576zM232 296L408 296C421.3 296 432 306.7 432 320C432 333.3 421.3 344 408 344L232 344C218.7 344 208 333.3 208 320C208 306.7 218.7 296 232 296z" /></svg>Remove
                                                </button>
                                            </form>
                                        </td>
                                    </tr>

                                    index++;
                                }

                            </tbody>

                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

