@model PlaylistEditViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 playlist-create-edit-card">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4 fw-bold">
                        Edit <span class="text-warning">Playlist</span>
                    </h2>

                    <form method="post" asp-action="Edit" enctype="multipart/form-data">
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label fw-semibold">Playlist Title</label>
                                    <input asp-for="Title" class="form-control" placeholder="Enter playlist title" />
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ImageFile" class="form-label fw-semibold">Art Cover</label>
                                    <input type="file" asp-for="ImageFile" class="form-control" />
                                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                </div>

                                <div class="p-3 rounded-4 border border-secondary border-opacity-25 bg-dark bg-opacity-10 mb-3">
                                    <div class="form-check form-switch d-flex align-items-center justify-content-between p-0 m-0">
                                        <div>
                                            <label asp-for="IsPublic" class="form-check-label fw-bold d-block mb-0">Public Playlist</label>
                                            <small class="text-white-50">Anyone can find and listen to this</small>
                                        </div>
                                        <input asp-for="IsPublic" class="form-check-input ms-0" type="checkbox" role="switch" style="width: 2.5em; height: 1.25em;">
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-3 pt-2 border-top-0">
                                    <button type="submit" class="btn btn-warning btn-lg rounded-4 px-5 shadow fw-semibold">
                                        Save Changes
                                    </button>
                                    <a asp-controller="Library" asp-action="MyLibraryIndex"
                                       class="btn btn-outline-warning btn-lg rounded-4 px-4">
                                        Cancel
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}