@model PlaylistCreateViewModel

<div class="container py-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="form-studio-card">

                <!-- Header -->
                <div class="form-studio-header">
                    <div class="form-studio-header__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="form-studio-header__title">Create <span>Playlist</span></h2>
                        <p class="form-studio-header__subtitle">Curate your personal collection</p>
                    </div>
                </div>

                <div class="form-studio-body">
                    <form method="post" asp-action="Create" enctype="multipart/form-data" id="playlist-create-form">

                        <!-- Section: Playlist Info -->
                        <div class="form-studio-section">
                            <div class="form-studio-section__label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                    <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                                </svg>
                                Playlist Info
                            </div>

                            <div class="form-studio-field">
                                <label asp-for="Title" class="form-studio-field__label">Playlist Title</label>
                                <input asp-for="Title" class="form-studio-field__input" placeholder="Enter playlist title…" />
                                <span asp-validation-for="Title" class="form-studio-field__error"></span>
                            </div>

                            <div class="form-studio-field mt-3">
                                <div class="form-studio-upload" id="artcover-upload">
                                    <div class="form-studio-upload__icon">🖼️</div>
                                    <div class="form-studio-upload__title">Cover Image</div>
                                    <div class="form-studio-upload__hint">PNG, JPG, WEBP recommended</div>
                                    <input type="file" asp-for="ImageFile" class="form-studio-upload__input" accept="image/*" />
                                    <div class="form-studio-upload__preview" id="artcover-preview"></div>
                                    <span asp-validation-for="ImageFile" class="form-studio-field__error mt-2 d-block text-center"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Section: Visibility -->
                        <div class="form-studio-section">
                            <div class="form-studio-section__label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                                    <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                                </svg>
                                Visibility
                            </div>

                            <div class="form-studio-toggle-card">
                                <div class="form-studio-toggle-card__info">
                                    <div class="form-studio-toggle-card__title">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" class="me-2 text-success">
                                            <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                                        </svg>
                                        Public Playlist
                                    </div>
                                    <div class="form-studio-toggle-card__desc">Anyone can find and listen to this playlist</div>
                                </div>
                                <label class="form-studio-toggle-card__switch">
                                    <input asp-for="IsPublic" type="checkbox" role="switch" />
                                    <span class="form-studio-toggle-card__track"></span>
                                </label>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="form-studio-actions">
                            <a asp-controller="Library" asp-action="MyLibraryIndex" class="form-studio-actions__cancel">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                                </svg>
                                Cancel
                            </a>
                            <button type="submit" class="form-studio-actions__submit form-studio-actions__submit--create">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                                </svg>
                                Create Playlist
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('ImageFile').addEventListener('change', function () {
            const preview = document.getElementById('artcover-preview');
            const wrap = document.getElementById('artcover-upload');
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.style.backgroundImage = `url('${e.target.result}')`;
                    preview.style.display = 'block';
                    wrap.classList.add('form-studio-upload--has-file');
                };
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}